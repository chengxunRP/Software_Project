<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    pageEyebrow = 'Organiser';
    pageHeading = 'Organiser Dashboard';
    pageLead = 'Manage your events, registrations and volunteers.';
    pageActions = '<a href="/organiser/events/new" class="btn-cc btn-cc-primary btn-cc-sm">+ Add Event</a>';
  %>
  <%- include('../partials/page-header') %>

  <main class="site-main">
    <div class="site-content overlap-panel max-1080">
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px">
        <div class="stat-card">
          <span class="stat-label">Total events created</span>
          <span class="stat-value"><%= stats.totalEvents %></span>
          <span class="stat-note">All events under your organisation</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Active events</span>
          <span class="stat-value green"><%= stats.activeEvents %></span>
          <span class="stat-note">Currently open or full</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Completed events</span>
          <span class="stat-value"><%= stats.completedEvents %></span>
          <span class="stat-note">Closed after delivery</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Cancelled events</span>
          <span class="stat-value amber"><%= stats.cancelledEvents %></span>
          <span class="stat-note">Events withdrawn</span>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:16px">
        <div class="stat-card">
          <span class="stat-label">Registered volunteers</span>
          <span class="stat-value green"><%= stats.totalRegisteredVolunteers %></span>
          <span class="stat-note">Confirmed volunteer registrations</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Attendance rate</span>
          <span class="stat-value"><%= stats.attendanceRate %></span>
          <span class="stat-note">Recorded attendance outcomes</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Avg. volunteers/event</span>
          <span class="stat-value amber"><%= stats.averageVolunteersPerEvent %></span>
          <span class="stat-note">Across all created events</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Volunteer hours</span>
          <span class="stat-value"><%= stats.totalVolunteerHours %></span>
          <span class="stat-note">Hours contributed by volunteers</span>
        </div>
      </div>

      <div class="dashboard-split" style="display:grid;grid-template-columns:1.35fr 1fr;gap:20px;align-items:start">
        <div class="card-cc overflow-hidden">
          <div class="panel-header">
            <span class="h-card">Upcoming events</span>
            <a href="/organiser/events" style="font-size:13.5px;font-weight:600">Manage all</a>
          </div>
          <% upcoming.forEach(function (u) { %>
            <div class="list-row">
              <div class="date-chip">
                <span class="month"><%= u.month %></span>
                <span class="day" style="font-size:18px"><%= u.day %></span>
              </div>
              <div class="flex-fill min-w-0">
                <div style="font-size:14.5px;font-weight:700;color:#23271F"><%= u.event_name %></div>
                <div class="d-flex align-items-center gap-2 mt-1 flex-wrap">
                  <span style="font-size:12px;font-weight:600;color:#6E7266">P <%= u.participants_filled %>/<%= u.participant_capacity %></span>
                  <div class="cap-bar-track flex-fill" style="max-width:90px">
                    <div class="cap-bar-fill" style="width:<%= u.participants.pct %>%;background:<%= u.participants.capColor %>"></div>
                  </div>
                  <span style="font-size:12px;font-weight:600;color:#6E7266">V <%= u.volunteers_filled %>/<%= u.volunteer_capacity %></span>
                  <div class="cap-bar-track flex-fill" style="max-width:90px">
                    <div class="cap-bar-fill" style="width:<%= u.volunteers.pct %>%;background:<%= u.volunteers.capColor %>"></div>
                  </div>
                </div>
              </div>
              <a href="/organiser/events/<%= u.id %>/registrations" style="font-size:13px;font-weight:600;flex-shrink:0">Registrations →</a>
            </div>
          <% }) %>
        </div>

        <div class="d-flex flex-column gap-3">
          <div class="card-cc overflow-hidden">
            <div class="panel-header">
              <span class="h-card">Needs attention</span>
            </div>
            <% alerts.forEach(function (a) { %>
              <div class="list-row align-items-start">
                <span class="attention-icon <%= a.tone === 'danger' ? 'danger' : 'warning' %>">!</span>
                <div>
                  <div style="font-size:13.5px;font-weight:600;color:#23271F;line-height:1.45"><%= a.text %></div>
                  <a href="<%= a.link %>" style="font-size:12.5px;font-weight:600"><%= a.linkText %></a>
                </div>
              </div>
            <% }) %>
          </div>

          <div class="card-cc" style="padding:20px">
            <div class="h-card mb-3">Attendance — last 3 events</div>
            <% attendance.forEach(function (a) { %>
              <div class="mb-3">
                <div class="d-flex justify-content-between" style="font-size:13px">
                  <span style="font-weight:600;color:#3C4038"><%= a.name %></span>
                  <span style="font-weight:700;color:#2E7D4F"><%= a.rate %></span>
                </div>
                <div class="cap-bar-track mt-1">
                  <div class="cap-bar-fill" style="width:<%= a.rate %>;background:#2E7D4F"></div>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
