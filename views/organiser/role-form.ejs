<%- include('../partials/header') %>
<%
  const isEdit = typeof formMode !== 'undefined' && formMode === 'edit';
  const formAction = isEdit
    ? '/organiser/events/' + event.event_id + '/roles/' + role_id + '/edit'
    : '/organiser/events/' + event.event_id + '/roles';
%>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    const pageEyebrow = 'Organiser';
    const pageHeading = isEdit ? 'Edit Volunteer Role' : 'Add Volunteer Role';
    const pageLead = 'Define volunteer duties for this event.';
    const pageActions = '<a href="/organiser/events/' + event.event_id + '/roles" class="btn-cc btn-cc-secondary btn-cc-sm">Cancel</a>';
  %>
  <%- include('../partials/page-header', { pageEyebrow: (typeof pageEyebrow !== 'undefined' ? pageEyebrow : ''), pageHeading: (typeof pageHeading !== 'undefined' ? pageHeading : ''), pageLead: (typeof pageLead !== 'undefined' ? pageLead : ''), pageActions: (typeof pageActions !== 'undefined' ? pageActions : '') }) %>

  <main class="site-main">
    <div class="site-content overlap-panel max-1040">
      <div class="breadcrumb-cc mb-0">
        <a href="/organiser/events/<%= event.event_id %>/roles" style="font-weight:600">← <%= event.event_name %></a>
        <span class="sep">/</span>
        <%= isEdit ? 'Edit Volunteer Role' : 'Add Volunteer Role' %>
      </div>

      <%- include('../partials/messages') %>

      <form method="POST" action="<%= formAction %>" class="card-cc" style="border-radius:16px;padding:26px;max-width:560px">
        <div class="mb-3">
          <label class="form-label-cc" for="role_name">Role name <span class="req">*</span></label>
          <input class="form-control-cc" type="text" id="role_name" name="role_name" maxlength="100" value="<%= role_name %>" required>
        </div>
        <div class="mb-3">
          <label class="form-label-cc" for="description">Description</label>
          <textarea class="form-control-cc" id="description" name="description" rows="4"><%= description %></textarea>
          <div class="form-hint">Shown to volunteers when they pick a preferred role.</div>
        </div>
        <div class="mb-3">
          <label class="form-label-cc" for="required_volunteers">Volunteers needed <span class="req">*</span></label>
          <input class="form-control-cc" type="number" id="required_volunteers" name="required_volunteers" min="1" style="max-width:160px" value="<%= required_volunteers %>" required>
        </div>
        <div class="d-flex gap-2 justify-content-end">
          <a href="/organiser/events/<%= event.event_id %>/roles" class="btn-cc btn-cc-secondary btn-cc-sm">Cancel</a>
          <button type="submit" class="btn-cc btn-cc-primary btn-cc-sm"><%= isEdit ? 'Save changes' : 'Save role' %></button>
        </div>
      </form>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
