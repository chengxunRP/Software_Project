<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    pageEyebrow = 'Organiser';
    pageHeading = 'Attendance Management';
    pageLead = 'Record attendance for participants and volunteers at this event.';
    pageActions = '';
  %>
  <%- include('../partials/page-header') %>

  <main class="site-main">
    <div class="site-content overlap-panel max-980">
      <div class="d-flex justify-content-end">
        <select class="form-select-cc" style="width:auto;max-width:100%;padding:9px 14px;border-radius:10px;font-size:13.5px;font-weight:600" onchange="if(this.value) location.href=this.value">
          <% eventOptions.forEach(function (o) { %>
            <option value="/organiser/events/<%= o.id %>/attendance" <%= String(o.id) === String(event.id) ? 'selected' : '' %>><%= o.event_name %> — <%= o.dateLabel %></option>
          <% }) %>
        </select>
      </div>

      <div class="stat-row-4" style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px">
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Registered</span>
          <span class="stat-value" style="font-size:26px"><%= summary.registered %></span>
        </div>
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Checked in</span>
          <span class="stat-value green" style="font-size:26px"><%= summary.attended %></span>
        </div>
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Absent</span>
          <span class="stat-value" style="font-size:26px;color:#B0433B"><%= summary.absent %></span>
        </div>
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Pending</span>
          <span class="stat-value amber" style="font-size:26px"><%= summary.pending %></span>
        </div>
      </div>

      <%- include('../partials/messages') %>

      <div class="table-cc">
        <div class="panel-header">
          <span class="h-card">Check-in <span style="color:#8B8778;font-weight:600;font-size:14px">(showing <%= rows.length %> of <%= summary.registered %>)</span></span>
        </div>
        <% if (!rows.length) { %>
          <div class="list-row">
            <div class="text-muted-cc" style="font-size:13.5px">No attendance records have been recorded.</div>
          </div>
        <% } %>
        <% rows.forEach(function (r) { %>
          <div class="list-row" data-attendance-row>
            <span class="avatar-cc sm" style="background:<%= r.avBg %>"><%= r.initials %></span>
            <div class="flex-fill min-w-0">
              <div style="font-weight:600;color:#23271F"><%= r.name %></div>
              <div style="font-size:12.5px;color:#8B8778"><%= r.participation_type %><%= r.role !== '—' ? ' · ' + r.role : '' %></div>
            </div>
            <span class="badge-cc <%= r.status === 'Attended' ? 'badge-cc-attended' : (r.status === 'Absent' ? 'badge-cc-absent' : 'badge-cc-pending') %>" data-attendance-badge style="font-size:11.5px;padding:4px 11px"><%= r.status %></span>
            <% if (r.status === 'Pending') { %>
              <div class="d-flex gap-2">
                <form method="POST" action="/organiser/events/<%= event.event_id %>/attendance">
                  <input type="hidden" name="registration_id" value="<%= r.registration_id %>">
                  <input type="hidden" name="attendance_status" value="Attended">
                  <button type="submit" class="btn-cc btn-cc-xs btn-cc-secondary">Mark Attended</button>
                </form>
                <form method="POST" action="/organiser/events/<%= event.event_id %>/attendance">
                  <input type="hidden" name="registration_id" value="<%= r.registration_id %>">
                  <input type="hidden" name="attendance_status" value="Absent">
                  <button type="submit" class="btn-cc btn-cc-xs btn-cc-secondary">Mark Absent</button>
                </form>
              </div>
            <% } else if (r.canCheckOut) { %>
              <form method="POST" action="/organiser/events/<%= event.event_id %>/attendance/checkout">
                <input type="hidden" name="registration_id" value="<%= r.registration_id %>">
                <button type="submit" class="btn-cc btn-cc-xs btn-cc-secondary">Check out</button>
              </form>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
