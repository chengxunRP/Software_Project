<%- include('../partials/header') %>
<div class="app-shell" id="appShell">
  <%- include('../partials/sidebar') %>
  <main class="app-main">
    <% topbarTitle = 'Assign Volunteers'; %>
    <% topbarActions = '<a href="/organiser/events/' + volunteerRole.event_id + '/roles" class="btn-cc btn-cc-secondary btn-cc-sm">Back to roles</a>'; %>
    <%- include('../partials/navbar') %>

    <div class="app-content max-1040">
      <div class="breadcrumb-cc mb-0">
        <a href="/organiser/events/<%= volunteerRole.event_id %>/roles" style="font-weight:600">← <%= volunteerRole.event_name %></a>
        <span class="sep">/</span>
        <%= volunteerRole.role_name %>
      </div>

      <%- include('../partials/messages') %>

      <% const isFull = assignedCount >= volunteerRole.required_volunteers; %>

      <div class="card-cc" style="border-radius:16px;padding:26px;margin-bottom:16px">
        <div class="panel-header" style="padding:0 0 12px 0;border:none">
          <div>
            <div style="font-size:15.5px;font-weight:700;color:#23271F"><%= volunteerRole.role_name %></div>
            <% if (volunteerRole.description) { %>
              <div style="font-size:13px;color:#6E7266"><%= volunteerRole.description %></div>
            <% } %>
          </div>
          <span class="badge-cc" style="background:<%= isFull ? '#FBEAE8' : '#E7F2EA' %>;color:<%= isFull ? '#B0433B' : '#1E4D33' %>">
            Assigned: <%= assignedCount %> / <%= volunteerRole.required_volunteers %>
          </span>
        </div>

        <% if (assigned.length) { %>
          <% assigned.forEach(function (person) { %>
            <div class="list-row">
              <span style="font-weight:600;color:#23271F;flex:1"><%= person.name %></span>
              <span style="font-size:12.5px;color:#8B8778"><%= person.email %></span>
            </div>
          <% }) %>
        <% } else { %>
          <div class="px-4 py-3" style="font-size:13px;color:#8B8778;font-style:italic">No volunteers assigned to this role yet.</div>
        <% } %>
      </div>

      <div class="card-cc overflow-hidden" style="border-radius:16px;padding:26px">
        <div class="h-card mb-3" style="font-size:15px">Assign confirmed volunteers</div>

        <% if (isFull) { %>
          <div class="px-4 py-3" style="font-size:13.5px;color:#B0433B;font-weight:600">Role is at capacity — no more volunteers can be assigned.</div>
        <% } else if (!eligible.length) { %>
          <div class="px-4 py-3" style="font-size:13px;color:#8B8778;font-style:italic">No confirmed volunteers are available to assign right now.</div>
        <% } else { %>
          <form method="POST" action="/organiser/events/<%= volunteerRole.event_id %>/roles/<%= volunteerRole.role_id %>/assign">
            <div class="d-flex flex-column gap-2 mb-3">
              <% eligible.forEach(function (person) { %>
                <label class="list-row" style="cursor:pointer">
                  <input type="checkbox" name="registration_ids" value="<%= person.registration_id %>">
                  <span style="font-weight:600;color:#23271F;flex:1"><%= person.name %></span>
                  <span style="font-size:12.5px;color:#8B8778"><%= person.email %></span>
                </label>
              <% }) %>
            </div>
            <button type="submit" class="btn-cc btn-cc-primary btn-cc-sm">Assign selected volunteers</button>
          </form>
        <% } %>
      </div>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
