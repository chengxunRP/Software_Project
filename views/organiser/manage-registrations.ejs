<%- include('../partials/header') %>
<div class="app-shell" id="appShell">
  <%- include('../partials/sidebar') %>
  <main class="app-main">
    <% topbarTitle = 'Manage Registrations'; %>
    <% topbarActions = ''; %>
    <%- include('../partials/navbar') %>

    <div class="app-content max-1020">
      <div class="d-flex justify-content-end">
        <select class="form-select-cc" style="width:auto;max-width:100%;padding:9px 14px;border-radius:10px;font-size:13.5px;font-weight:600" onchange="if(this.value) location.href=this.value">
          <% eventOptions.forEach(function (o) { %>
            <option value="/organiser/events/<%= o.id %>/registrations" <%= String(o.id) === String(event.id) ? 'selected' : '' %>><%= o.name %> — <%= o.when.split(' · ')[0] %></option>
          <% }) %>
        </select>
      </div>

      <div class="stat-row-4" style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px">
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Capacity</span>
          <span class="stat-value" style="font-size:26px"><%= summary.capacity %></span>
        </div>
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Confirmed</span>
          <span class="stat-value green" style="font-size:26px"><%= summary.confirmed %></span>
        </div>
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Waiting list</span>
          <span class="stat-value amber" style="font-size:26px"><%= summary.waitlist %></span>
        </div>
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Cancellations</span>
          <span class="stat-value" style="font-size:26px;color:#6E7266"><%= summary.cancellations %></span>
        </div>
      </div>

      <%- include('../partials/messages') %>

      <div class="table-cc">
        <div class="panel-header">
          <span class="h-card">Confirmed volunteers <span style="color:#8B8778;font-weight:600;font-size:14px">(showing <%= confirmed.length %> of <%= summary.confirmed %>)</span></span>
          <button type="button" class="btn-cc btn-cc-secondary btn-cc-xs">Export CSV</button>
        </div>
        <div class="table-scroll">
          <div class="table-cc-head" style="grid-template-columns:1.8fr 1.6fr 1.1fr 1fr 1.1fr">
            <span>Volunteer</span><span>Contact</span><span>Registered on</span><span>Status</span><span style="text-align:right">Action</span>
          </div>
          <% confirmed.forEach(function (c) { %>
            <div class="table-cc-row" style="grid-template-columns:1.8fr 1.6fr 1.1fr 1fr 1.1fr">
              <div class="d-flex align-items-center gap-2">
                <span class="avatar-cc sm" style="background:<%= c.avBg %>"><%= c.initials %></span>
                <span style="font-weight:600;color:#23271F"><%= c.name %></span>
              </div>
              <span class="text-muted-cc" style="font-size:13px"><%= c.contact %></span>
              <span class="text-muted-cc" style="font-size:13.5px"><%= c.date %></span>
              <span><span class="badge-cc badge-cc-confirmed" style="font-size:11.5px;padding:4px 10px">Confirmed</span></span>
              <div class="d-flex justify-content-end">
                <button type="button" class="btn-cc btn-cc-danger-outline btn-cc-xs" data-open-modal data-event-name="<%= c.name %>">Remove</button>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="table-cc">
        <div class="panel-header">
          <span class="h-card">Waiting list <span style="color:#8B8778;font-weight:600;font-size:14px">(in order of registration)</span></span>
        </div>
        <% waitlist.forEach(function (w) { %>
          <div class="list-row">
            <span style="width:30px;height:30px;border-radius:9px;background:#FBF3DF;color:#8A5E08;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;flex-shrink:0"><%= w.pos %></span>
            <span class="avatar-cc sm" style="background:<%= w.avBg %>"><%= w.initials %></span>
            <div class="flex-fill">
              <div style="font-weight:600;color:#23271F"><%= w.name %></div>
              <div style="font-size:12.5px;color:#8B8778"><%= w.contact %> · joined <%= w.date %></div>
            </div>
            <span class="badge-cc badge-cc-waitlist">Waitlist #<%= w.pos %></span>
          </div>
        <% }) %>
      </div>
    </div>
  </main>
</div>

<div class="modal-cc" id="confirmModal">
  <div class="modal-cc-dialog">
    <div class="modal-icon">!</div>
    <div>
      <div style="font-size:19px;font-weight:800;color:#23271F">Remove this volunteer?</div>
      <div class="text-muted-cc mt-2" style="font-size:14.5px;line-height:1.55">Removing <b id="modalEventName">this volunteer</b> will free a place for the waiting list. Preview only — no backend action.</div>
    </div>
    <div class="d-flex gap-2 justify-content-end">
      <button type="button" class="btn-cc btn-cc-secondary" data-close-modal>Keep</button>
      <button type="button" class="btn-cc btn-cc-danger" data-close-modal>Remove</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
