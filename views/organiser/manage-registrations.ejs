<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    pageEyebrow = 'Organiser';
    pageHeading = 'Manage Registrations';
    pageLead = 'Review confirmed participants, confirmed volunteers and both waiting lists for this event.';
    pageActions = '';
  %>
  <%- include('../partials/page-header') %>

  <main class="site-main">
    <div class="site-content overlap-panel max-1020">
      <div class="d-flex justify-content-end">
        <select class="form-select-cc" style="width:auto;max-width:100%;padding:9px 14px;border-radius:10px;font-size:13.5px;font-weight:600" onchange="if(this.value) location.href=this.value">
          <% eventOptions.forEach(function (o) { %>
            <option value="/organiser/events/<%= o.id %>/registrations" <%= String(o.id) === String(event.id) ? 'selected' : '' %>><%= o.name %> — <%= o.when.split(' · ')[0] %></option>
          <% }) %>
        </select>
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Confirmed participants</span>
          <span class="stat-value green" style="font-size:26px"><%= summary.confirmedParticipants %></span>
          <span class="stat-note">of <%= summary.participant_capacity %> capacity</span>
        </div>
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Confirmed volunteers</span>
          <span class="stat-value green" style="font-size:26px"><%= summary.confirmedVolunteers %></span>
          <span class="stat-note">of <%= summary.volunteer_capacity %> capacity</span>
        </div>
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Waiting lists</span>
          <span class="stat-value amber" style="font-size:26px"><%= summary.participantWaitlist + summary.volunteerWaitlist %></span>
          <span class="stat-note">P <%= summary.participantWaitlist %> · V <%= summary.volunteerWaitlist %> · <%= summary.cancellations %> cancellations</span>
        </div>
      </div>

      <%- include('../partials/messages') %>

      <div class="table-cc">
        <div class="panel-header">
          <span class="h-card">Participants <span style="color:#8B978F;font-weight:600;font-size:14px">(showing <%= confirmedParticipants.length %> of <%= summary.confirmedParticipants %>)</span></span>
        </div>
        <div class="table-scroll">
          <div class="table-cc-head" style="grid-template-columns:1.8fr 1.6fr 1.1fr 1fr 1.1fr">
            <span>Name</span><span>Contact</span><span>Registered on</span><span>Type</span><span style="text-align:right">Action</span>
          </div>
          <% confirmedParticipants.forEach(function (c) { %>
            <div class="table-cc-row" style="grid-template-columns:1.8fr 1.6fr 1.1fr 1fr 1.1fr">
              <div class="d-flex align-items-center gap-2">
                <span class="avatar-cc sm" style="background:<%= c.avBg %>"><%= c.initials %></span>
                <span style="font-weight:600;color:#17342C"><%= c.name %></span>
              </div>
              <span class="text-muted-cc" style="font-size:13px"><%= c.contact %></span>
              <span class="text-muted-cc" style="font-size:13.5px"><%= c.date %></span>
              <span><span class="badge-cc" style="background:#E9EDF6;color:#3B5384;font-size:11.5px;padding:4px 10px">Participant</span></span>
              <div class="d-flex justify-content-end">
                <button type="button" class="btn-cc btn-cc-danger-outline btn-cc-xs" data-open-modal data-event-name="<%= c.name %>">Remove</button>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="table-cc">
        <div class="panel-header">
          <span class="h-card">Volunteers <span style="color:#8B978F;font-weight:600;font-size:14px">(showing <%= confirmedVolunteers.length %> of <%= summary.confirmedVolunteers %>)</span></span>
          <a href="/organiser/events/<%= event.id %>/roles" class="btn-cc btn-cc-secondary btn-cc-xs">Assign roles</a>
        </div>
        <div class="table-scroll">
          <div class="table-cc-head" style="grid-template-columns:1.8fr 1.6fr 1.1fr 1fr 1.1fr">
            <span>Name</span><span>Contact</span><span>Registered on</span><span>Type</span><span style="text-align:right">Action</span>
          </div>
          <% confirmedVolunteers.forEach(function (c) { %>
            <div class="table-cc-row" style="grid-template-columns:1.8fr 1.6fr 1.1fr 1fr 1.1fr">
              <div class="d-flex align-items-center gap-2">
                <span class="avatar-cc sm" style="background:<%= c.avBg %>"><%= c.initials %></span>
                <span style="font-weight:600;color:#17342C"><%= c.name %></span>
              </div>
              <span class="text-muted-cc" style="font-size:13px"><%= c.contact %></span>
              <span class="text-muted-cc" style="font-size:13.5px"><%= c.date %></span>
              <span><span class="badge-cc" style="background:#E8F7F0;color:#056047;font-size:11.5px;padding:4px 10px">Volunteer</span></span>
              <div class="d-flex justify-content-end">
                <button type="button" class="btn-cc btn-cc-danger-outline btn-cc-xs" data-open-modal data-event-name="<%= c.name %>">Remove</button>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="table-cc">
        <div class="panel-header">
          <span class="h-card">Participant waiting list <span style="color:#8B978F;font-weight:600;font-size:14px">(<%= summary.participantWaitlist %>)</span></span>
        </div>
        <% if (!participantWaitlist.length) { %>
          <div class="list-row text-muted-cc" style="font-size:13.5px">No one on the participant waiting list.</div>
        <% } %>
        <% participantWaitlist.forEach(function (w) { %>
          <div class="list-row">
            <span style="width:30px;height:30px;border-radius:9px;background:#FFF7DF;color:#8A6008;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;flex-shrink:0"><%= w.pos %></span>
            <span class="avatar-cc sm" style="background:<%= w.avBg %>"><%= w.initials %></span>
            <div class="flex-fill">
              <div style="font-weight:600;color:#17342C"><%= w.name %></div>
              <div style="font-size:12.5px;color:#8B978F"><%= w.contact %> · joined <%= w.date %></div>
            </div>
            <span class="badge-cc badge-cc-waitlist">Waitlist #<%= w.pos %></span>
          </div>
        <% }) %>
      </div>

      <div class="table-cc">
        <div class="panel-header">
          <span class="h-card">Volunteer waiting list <span style="color:#8B978F;font-weight:600;font-size:14px">(<%= summary.volunteerWaitlist %>)</span></span>
        </div>
        <% if (!volunteerWaitlist.length) { %>
          <div class="list-row text-muted-cc" style="font-size:13.5px">No one on the volunteer waiting list.</div>
        <% } %>
        <% volunteerWaitlist.forEach(function (w) { %>
          <div class="list-row">
            <span style="width:30px;height:30px;border-radius:9px;background:#FFF7DF;color:#8A6008;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;flex-shrink:0"><%= w.pos %></span>
            <span class="avatar-cc sm" style="background:<%= w.avBg %>"><%= w.initials %></span>
            <div class="flex-fill">
              <div style="font-weight:600;color:#17342C"><%= w.name %></div>
              <div style="font-size:12.5px;color:#8B978F"><%= w.contact %> · joined <%= w.date %></div>
            </div>
            <span class="badge-cc badge-cc-waitlist">Waitlist #<%= w.pos %></span>
          </div>
        <% }) %>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>

<div class="modal-cc" id="confirmModal">
  <div class="modal-cc-dialog">
    <div class="modal-icon">!</div>
    <div>
      <div style="font-size:19px;font-weight:800;color:#17342C">Remove this registration?</div>
      <div class="text-muted-cc mt-2" style="font-size:14.5px;line-height:1.55">Removing <b id="modalEventName">this person</b> will free a place for the matching waiting list. Preview only — no backend action.</div>
    </div>
    <div class="d-flex gap-2 justify-content-end">
      <button type="button" class="btn-cc btn-cc-secondary" data-close-modal>Keep</button>
      <button type="button" class="btn-cc btn-cc-danger" data-close-modal>Remove</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
