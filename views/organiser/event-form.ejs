<%- include('../partials/header') %>
<div class="app-shell" id="appShell">
  <%- include('../partials/sidebar') %>
  <main class="app-main">
    <% topbarTitle = formMode === 'create' ? 'Add Event' : 'Edit Event'; %>
    <% topbarActions = '<a href="/organiser/events" class="btn-cc btn-cc-secondary btn-cc-sm">Discard changes</a><a href="/organiser/events" class="btn-cc btn-cc-primary btn-cc-sm">Save event</a>'; %>
    <%- include('../partials/navbar') %>

    <div class="app-content max-1060">
      <div class="breadcrumb-cc mb-0">
        <a href="/organiser/events" style="font-weight:600">← Manage Events</a>
        <span class="sep">/</span>
        <%= formMode === 'create' ? 'Add Event' : 'Edit Event' %>
      </div>

      <%- include('../partials/messages') %>

      <form data-preview-only class="details-grid" style="grid-template-columns:1fr 320px">
        <div class="d-flex flex-column gap-3">
          <div class="card-cc" style="border-radius:16px;padding:26px">
            <div class="h-card mb-3" style="font-size:15px">Event details</div>
            <div class="mb-3">
              <label class="form-label-cc" for="event_name">Event name <span class="req">*</span></label>
              <input class="form-control-cc" type="text" id="event_name" name="event_name" value="<%= event.event_name || '' %>">
            </div>
            <div class="form-grid-2 mb-3">
              <div>
                <label class="form-label-cc" for="category_id">Category <span class="req">*</span></label>
                <select class="form-select-cc" id="category_id" name="category_id">
                  <% categories.forEach(function (c) { %>
                    <option value="<%= c.category_id %>" <%= String(event.category_id) === String(c.category_id) ? 'selected' : '' %>><%= c.name %></option>
                  <% }) %>
                </select>
              </div>
              <div>
                <label class="form-label-cc" for="location">Location <span class="req">*</span></label>
                <input class="form-control-cc" type="text" id="location" name="location" value="<%= event.location || '' %>">
              </div>
            </div>
            <div>
              <label class="form-label-cc" for="description">Description <span class="req">*</span></label>
              <textarea class="form-control-cc" id="description" name="description" rows="5"><%= event.description || '' %></textarea>
              <div class="form-hint">Shown on the public event page. Include what to bring and who the event suits.</div>
            </div>
          </div>

          <div class="card-cc" style="border-radius:16px;padding:26px">
            <div class="h-card mb-3" style="font-size:15px">Schedule & capacity</div>
            <div class="form-grid-2 mb-3">
              <div>
                <label class="form-label-cc" for="start_datetime">Start date & time <span class="req">*</span></label>
                <input class="form-control-cc" type="datetime-local" id="start_datetime" name="start_datetime" value="<%= event.start_datetime || '' %>">
              </div>
              <div>
                <label class="form-label-cc" for="end_datetime">End date & time <span class="req">*</span></label>
                <input class="form-control-cc" type="datetime-local" id="end_datetime" name="end_datetime" value="<%= event.end_datetime || '' %>">
              </div>
            </div>
            <div class="form-grid-2 mb-3">
              <div>
                <label class="form-label-cc" for="participant_capacity">Participant capacity <span class="req">*</span></label>
                <input class="form-control-cc" type="number" id="participant_capacity" name="participant_capacity" value="<%= event.participant_capacity || '' %>">
                <div class="form-hint">Ordinary community participants. A participant waiting list opens when this is full.</div>
              </div>
              <div>
                <label class="form-label-cc" for="volunteer_capacity">Volunteer capacity <span class="req">*</span></label>
                <input class="form-control-cc" type="number" id="volunteer_capacity" name="volunteer_capacity" value="<%= event.volunteer_capacity || '' %>">
                <div class="form-hint">Helpers assisting at the event. A volunteer waiting list opens when this is full.</div>
              </div>
            </div>
            <div>
              <label class="form-label-cc" for="registration_deadline">Registration deadline <span class="req">*</span></label>
              <input class="form-control-cc" type="datetime-local" id="registration_deadline" name="registration_deadline" value="<%= event.registration_deadline || '' %>">
            </div>
          </div>
        </div>

        <div class="d-flex flex-column gap-3 sticky-panel">
          <div class="card-cc" style="border-radius:16px;padding:22px">
            <div class="h-card mb-3" style="font-size:15px">Event status</div>
            <div class="d-flex flex-column gap-2">
              <% const statuses = [
                { value: 'Published', label: 'Published', note: 'Visible in the catalogue, open for registration' },
                { value: 'Draft', label: 'Draft', note: 'Hidden from the public catalogue' },
                { value: 'Registration closed', label: 'Registration closed', note: 'Visible, but no new sign-ups' }
              ]; %>
              <% statuses.forEach(function (s) { %>
                <% const selected = (event.status === s.value) || (s.value === 'Published' && event.status === 'Full') || (formMode === 'create' && s.value === 'Draft' && !event.status); %>
                <label class="status-option <%= selected ? 'active' : '' %>">
                  <input type="radio" name="status" value="<%= s.value %>" <%= selected ? 'checked' : '' %>>
                  <div>
                    <div style="font-size:14px;font-weight:700;color:<%= selected ? '#1E4D33' : '#23271F' %>"><%= s.label %></div>
                    <div style="font-size:12px;color:<%= selected ? '#4E6B57' : '#8B8778' %>"><%= s.note %></div>
                  </div>
                </label>
              <% }) %>
            </div>
          </div>

          <% if (formMode === 'edit' && event.participants_filled !== undefined) { %>
          <div class="card-cc" style="border-radius:16px;padding:22px">
            <div class="h-card mb-2" style="font-size:15px">Current sign-ups</div>
            <div class="d-flex flex-column gap-3 mb-2">
              <div>
                <div class="cap-bar-meta" style="font-size:13px">
                  <span style="color:#6E7266">Participants <%= event.participants_filled %> of <%= event.participant_capacity %></span>
                  <span style="color:<%= event.participants.capColor %>"><%= event.participants.full ? 'Full' : (event.participants.left + ' left') %></span>
                </div>
                <div class="cap-bar-track" style="height:7px">
                  <div class="cap-bar-fill" style="width:<%= event.participants.pct %>%;background:<%= event.participants.capColor %>"></div>
                </div>
              </div>
              <div>
                <div class="cap-bar-meta" style="font-size:13px">
                  <span style="color:#6E7266">Volunteers <%= event.volunteers_filled %> of <%= event.volunteer_capacity %></span>
                  <span style="color:<%= event.volunteers.capColor %>"><%= event.volunteers.full ? 'Full' : (event.volunteers.left + ' left') %></span>
                </div>
                <div class="cap-bar-track" style="height:7px">
                  <div class="cap-bar-fill" style="width:<%= event.volunteers.pct %>%;background:<%= event.volunteers.capColor %>"></div>
                </div>
              </div>
            </div>
            <a href="/organiser/events/<%= event.id %>/registrations" style="font-size:13.5px;font-weight:600">Manage registrations →</a>
          </div>
          <% } %>
        </div>
      </form>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
