<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    const pageEyebrow = 'Organiser';
    const pageHeading = 'Volunteer Role Assignment';
    const pageLead = 'Assign confirmed volunteer registrations to roles for this event.';
    const pageActions = '<a href="/organiser/roles" class="btn-cc btn-cc-secondary btn-cc-sm">Back to roles</a><a href="/organiser/events/' + event.id + '/roles/new" class="btn-cc btn-cc-primary btn-cc-sm">+ Add role</a>';
  %>
  <%- include('../partials/page-header', { pageEyebrow: (typeof pageEyebrow !== 'undefined' ? pageEyebrow : ''), pageHeading: (typeof pageHeading !== 'undefined' ? pageHeading : ''), pageLead: (typeof pageLead !== 'undefined' ? pageLead : ''), pageActions: (typeof pageActions !== 'undefined' ? pageActions : '') }) %>

  <main class="site-main">
    <div class="site-content overlap-panel max-1040">
      <div class="d-flex justify-content-end">
        <select class="form-select-cc" style="width:auto;max-width:100%;padding:9px 14px;border-radius:10px;font-size:13.5px;font-weight:600" onchange="if(this.value) location.href=this.value">
          <% eventOptions.forEach(function (o) { %>
            <option value="/organiser/events/<%= o.id %>/roles" <%= String(o.id) === String(event.id) ? 'selected' : '' %>><%= o.event_name %> — <%= o.dateLabel %></option>
          <% }) %>
        </select>
      </div>

      <%- include('../partials/messages') %>

      <div class="details-grid" style="grid-template-columns:1fr 320px">
        <div class="d-flex flex-column gap-3">
          <% if (!roles.length) { %>
            <div class="card-cc" style="padding:24px">
              <div class="text-muted-cc" style="font-size:13.5px">No volunteer roles have been created for this event yet.</div>
              <a href="/organiser/events/<%= event.id %>/roles/new" class="btn-cc btn-cc-primary btn-cc-sm mt-3">+ Add role</a>
            </div>
          <% } %>
          <% roles.forEach(function (role) { %>
            <div class="card-cc overflow-hidden">
              <div class="panel-header">
                <div>
                  <div style="font-size:15.5px;font-weight:700;color:#12161C"><%= role.name %></div>
                  <div style="font-size:13px;color:#6B7280"><%= role.desc %></div>
                </div>
                <span class="badge-cc" style="background:<%= role.capBg %>;color:<%= role.capFg %>"><%= role.cap %></span>
              </div>
              <% role.people.forEach(function (p) { %>
                <div class="list-row">
                  <span class="avatar-cc sm" style="background:<%= p.avBg %>;width:30px;height:30px;font-size:11.5px"><%= p.initials %></span>
                  <span style="font-weight:600;color:#12161C;flex:1"><%= p.name %></span>
                </div>
              <% }) %>
              <% if (role.hasSpace) { %>
                <div class="px-4 py-3" style="font-size:13px;color:#8A93A6;font-style:italic"><%= role.spaceNote %></div>
              <% } %>
              <div class="d-flex gap-1 flex-wrap px-4 py-3" style="border-top:1px solid #E2E6ED">
                <a href="/organiser/events/<%= event.id %>/roles/<%= role.volunteer_role_id %>/assign" class="btn-cc btn-cc-primary btn-cc-xs">Assign</a>
                <a href="/organiser/events/<%= event.id %>/roles/<%= role.volunteer_role_id %>/edit" class="btn-cc btn-cc-secondary btn-cc-xs">Edit</a>
                <form method="POST" action="/organiser/events/<%= event.id %>/roles/<%= role.volunteer_role_id %>/delete" onsubmit="return confirm('Delete role <%= role.name %>?');">
                  <button type="submit" class="btn-cc btn-cc-danger-outline btn-cc-xs">Delete</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>

        <div class="card-cc overflow-hidden sticky-panel">
          <div class="panel-header flex-column align-items-start">
            <span class="h-card" style="font-size:15.5px">Unassigned volunteers</span>
            <span style="font-size:12.5px;color:#8A93A6">Assign each volunteer from the Assign page for a role</span>
          </div>
          <% if (!unassigned.length) { %>
            <div class="list-row">
              <div class="text-muted-cc" style="font-size:13.5px">No unassigned confirmed volunteers.</div>
            </div>
          <% } %>
          <% unassigned.forEach(function (u) { %>
            <div class="list-row">
              <span class="avatar-cc sm" style="background:<%= u.avBg %>;width:30px;height:30px;font-size:11.5px"><%= u.initials %></span>
              <span style="font-size:13.5px;font-weight:600;color:#12161C;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= u.name %></span>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
