<%- include('../partials/header') %>
<div class="app-shell" id="appShell">
  <%- include('../partials/sidebar') %>
  <main class="app-main">
    <% topbarTitle = 'Volunteer Role Assignment'; %>
    <% topbarActions = ''; %>
    <%- include('../partials/navbar') %>

    <div class="app-content max-1040">
      <div class="d-flex justify-content-end">
        <select class="form-select-cc" style="width:auto;max-width:100%;padding:9px 14px;border-radius:10px;font-size:13.5px;font-weight:600" onchange="if(this.value) location.href=this.value">
          <% eventOptions.forEach(function (o) { %>
            <option value="/organiser/events/<%= o.id %>/roles" <%= String(o.id) === String(event.id) ? 'selected' : '' %>><%= o.event_name %> — <%= o.dateLabel %></option>
          <% }) %>
        </select>
      </div>

      <%- include('../partials/messages') %>

      <div class="details-grid" style="grid-template-columns:1fr 320px">
        <div class="d-flex flex-column gap-3">
          <% roles.forEach(function (role) { %>
            <div class="card-cc overflow-hidden">
              <div class="panel-header">
                <div>
                  <div style="font-size:15.5px;font-weight:700;color:#23271F"><%= role.name %></div>
                  <div style="font-size:13px;color:#6E7266"><%= role.desc %></div>
                </div>
                <span class="badge-cc" style="background:<%= role.capBg %>;color:<%= role.capFg %>"><%= role.cap %></span>
              </div>
              <% role.people.forEach(function (p) { %>
                <div class="list-row">
                  <span class="avatar-cc sm" style="background:<%= p.avBg %>;width:30px;height:30px;font-size:11.5px"><%= p.initials %></span>
                  <span style="font-weight:600;color:#23271F;flex:1"><%= p.name %></span>
                  <button type="button" class="btn-cc btn-cc-secondary btn-cc-xs">Unassign</button>
                </div>
              <% }) %>
              <% if (role.hasSpace) { %>
                <div class="px-4 py-3" style="font-size:13px;color:#8B8778;font-style:italic"><%= role.spaceNote %></div>
              <% } %>
            </div>
          <% }) %>
        </div>

        <div class="card-cc overflow-hidden sticky-panel">
          <div class="panel-header flex-column align-items-start">
            <span class="h-card" style="font-size:15.5px">Unassigned volunteers</span>
            <span style="font-size:12.5px;color:#8B8778">Assign each volunteer to a role</span>
          </div>
          <% unassigned.forEach(function (u) { %>
            <form class="list-row" data-preview-only>
              <input type="hidden" name="event_id" value="<%= event.id %>">
              <span class="avatar-cc sm" style="background:<%= u.avBg %>;width:30px;height:30px;font-size:11.5px"><%= u.initials %></span>
              <span style="font-size:13.5px;font-weight:600;color:#23271F;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= u.name %></span>
              <select class="form-select-cc" name="volunteer_role_id" style="width:auto;padding:6px 8px;border-radius:8px;font-size:12px;font-weight:600">
                <option value="">Assign…</option>
                <% roleOptions.forEach(function (r) { %>
                  <option value="<%= r.volunteer_role_id %>"><%= r.name %></option>
                <% }) %>
              </select>
            </form>
          <% }) %>
        </div>
      </div>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
