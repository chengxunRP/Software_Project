<%- include('../partials/header') %>
<div class="app-shell" id="appShell">
  <%- include('../partials/sidebar') %>
  <main class="app-main">
    <% topbarTitle = 'Manage Events'; %>
    <% topbarActions = '<a href="/organiser/events/new" class="btn-cc btn-cc-primary btn-cc-sm">+ Add Event</a>'; %>
    <%- include('../partials/navbar') %>

    <div class="app-content">
      <div class="d-flex gap-2 align-items-center flex-wrap">
        <input type="text" class="form-control-cc" style="max-width:320px;padding:10px 14px;border-radius:10px;font-size:14px;background:#fff" placeholder="Search events…" data-preview-only>
        <select class="form-select-cc" style="width:auto;padding:10px 12px;border-radius:10px;font-size:14px;background:#fff">
          <option>All statuses</option><option>Published</option><option>Draft</option><option>Full</option><option>Completed</option><option>Cancelled</option>
        </select>
        <select class="form-select-cc" style="width:auto;padding:10px 12px;border-radius:10px;font-size:14px;background:#fff">
          <option>All categories</option>
          <% categories.forEach(function (c) { %>
            <option><%= c.name %></option>
          <% }) %>
        </select>
        <span class="ms-auto text-soft" style="font-size:13.5px">Showing <%= rows.length %> of 24 events</span>
      </div>

      <div class="table-cc mt-1">
        <div class="table-scroll">
          <div class="table-cc-head" style="grid-template-columns:2.2fr 0.9fr 1.1fr 1.4fr 0.9fr 1.4fr">
            <span>Event</span><span>Category</span><span>Date & time</span><span>Capacity</span><span>Status</span><span style="text-align:right">Actions</span>
          </div>
          <% rows.forEach(function (r) { %>
            <%
              const statusClass = {
                Published: 'badge-cc-published',
                Draft: 'badge-cc-draft',
                Full: 'badge-cc-warning',
                Completed: 'badge-cc-completed',
                Cancelled: 'badge-cc-danger'
              }[r.status] || 'badge-cc-muted';
            %>
            <div class="table-cc-row" style="grid-template-columns:2.2fr 0.9fr 1.1fr 1.4fr 0.9fr 1.4fr">
              <div>
                <div style="font-weight:700;color:#23271F"><%= r.name %></div>
                <div style="font-size:12.5px;color:#8B8778"><%= r.loc %></div>
              </div>
              <span class="text-muted-cc" style="font-size:13.5px"><%= r.cat %></span>
              <span class="text-muted-cc" style="font-size:13.5px"><%= r.when %></span>
              <div>
                <div style="font-size:12px;font-weight:600;color:#6E7266">P <%= r.participants_filled %>/<%= r.participant_capacity %></div>
                <div style="font-size:12px;font-weight:600;color:#6E7266">V <%= r.volunteers_filled %>/<%= r.volunteer_capacity %></div>
              </div>
              <span><span class="badge-cc <%= statusClass %>" style="font-size:11.5px;padding:4px 10px"><%= r.status %></span></span>
              <div class="d-flex gap-1 justify-content-end flex-wrap">
                <a href="/events/<%= r.id %>" class="btn-cc btn-cc-secondary btn-cc-xs">View</a>
                <a href="/organiser/events/<%= r.id %>/edit" class="btn-cc btn-cc-secondary btn-cc-xs">Edit</a>
                <% if (r.cancellable) { %>
                  <button type="button" class="btn-cc btn-cc-danger-outline btn-cc-xs" data-open-modal data-event-name="<%= r.name %>">Cancel</button>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </main>
</div>

<div class="modal-cc" id="confirmModal">
  <div class="modal-cc-dialog" style="width:460px">
    <div class="modal-icon">!</div>
    <div>
      <div style="font-size:19px;font-weight:800;color:#23271F">Cancel this event?</div>
      <div class="text-muted-cc mt-2" style="font-size:14.5px;line-height:1.55">Cancelling <b style="color:#3C4038" id="modalEventName">this event</b> will notify all confirmed and waitlisted participants and volunteers by email. This cannot be undone.</div>
    </div>
    <div class="d-flex gap-2 justify-content-end">
      <button type="button" class="btn-cc btn-cc-secondary" data-close-modal>Keep event</button>
      <button type="button" class="btn-cc btn-cc-danger" data-close-modal>Yes, cancel event</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
