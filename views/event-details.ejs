<%- include('partials/header') %>
<div class="site-page public-page">
  <%- include('partials/navbar') %>

  <%
    const pageEyebrow = 'Event details';
    const pageHeading = event.event_name;
    const pageLead = 'Organised by ' + event.organiser;
  %>
  <%- include('partials/page-header', { pageEyebrow: (typeof pageEyebrow !== 'undefined' ? pageEyebrow : ''), pageHeading: (typeof pageHeading !== 'undefined' ? pageHeading : ''), pageLead: (typeof pageLead !== 'undefined' ? pageLead : ''), pageActions: (typeof pageActions !== 'undefined' ? pageActions : '') }) %>

  <main class="site-main">
    <div class="section-wrap overlap-panel" style="max-width:1120px">
      <div class="breadcrumb-cc mb-3">
        <a href="/events">Event Catalogue</a>
        <span class="sep">/</span>
        <%= event.event_name %>
      </div>

      <div class="details-grid">
        <div class="d-flex flex-column gap-4">
          <%- include('partials/event-card-panel', { category: event.category, image: event.image }) %>

          <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
            <span class="badge-cc badge-cc-cat" style="background:<%= event.badgeBg %>;color:<%= event.badgeFg %>"><%= event.category %></span>
            <span class="badge-cc <%= event.statusBadgeClass %>"><%= event.statusLabel %></span>
            <% if (event.participants.full || event.volunteers.full) { %>
              <span class="badge-cc badge-cc-warning">Capacity tight</span>
            <% } %>
            <% if (event.full) { %>
              <span class="badge-cc badge-cc-full">Both full</span>
            <% } %>
          </div>

          <div class="card-cc">
            <div class="card-cc-body" style="padding:24px">
              <h2 class="h-card mb-3" style="font-size:18px">About this event</h2>
              <p class="mb-0" style="font-size:15px;line-height:1.7;color:#33394A"><%= event.description %></p>
            </div>
          </div>

          <% if (roles && roles.length) { %>
          <div class="card-cc">
            <div class="card-cc-body" style="padding:24px">
              <h2 class="h-card mb-3" style="font-size:18px">Volunteer roles</h2>
              <p class="text-muted-cc mb-3" style="font-size:13.5px">Shown when you choose to join as a Volunteer.</p>
              <div class="d-flex flex-column gap-3">
                <% roles.forEach(function (r) { %>
                  <% const roleFull = r.filled >= r.capacity; %>
                  <% const roleNear = !roleFull && r.capacity && (r.filled / r.capacity) >= 0.8; %>
                  <div class="d-flex align-items-center justify-content-between gap-3 p-3 role-row">
                    <div>
                      <div style="font-size:15px;font-weight:700;color:#12161C"><%= r.name %></div>
                      <div style="font-size:13.5px;color:#6B7280"><%= r.description %></div>
                    </div>
                    <span class="badge-cc" style="background:<%= roleFull ? '#FFF0EE' : (roleNear ? '#FFF7DF' : '#E8F7F0') %>;color:<%= roleFull ? '#E9564D' : (roleNear ? '#8A6008' : '#087F5B') %>">
                      <%= r.filled %> of <%= r.capacity %> filled
                    </span>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
          <% } %>
        </div>

        <div class="d-flex flex-column gap-3 sticky-panel hide-mobile">
          <div class="card-cc join-panel">
            <div class="card-cc-body" style="padding:24px">
              <div class="d-flex flex-column gap-3" style="font-size:14.5px">
                <div class="d-flex justify-content-between gap-2"><span class="text-muted-cc fw-medium">Date</span><span class="fw-semibold text-ink text-end"><%= event.dateLabel %></span></div>
                <div class="d-flex justify-content-between gap-2"><span class="text-muted-cc fw-medium">Time</span><span class="fw-semibold text-ink text-end"><%= event.timeLabel %></span></div>
                <div class="d-flex justify-content-between gap-2"><span class="text-muted-cc fw-medium">Location</span><span class="fw-semibold text-ink text-end"><%= event.location %></span></div>
                <div class="d-flex justify-content-between gap-2"><span class="text-muted-cc fw-medium">Registration closes</span><span class="fw-semibold text-ink text-end"><%= event.deadlineLabel %></span></div>
              </div>

              <hr class="my-3" style="border-color:#E2E6ED;opacity:1">

              <div class="d-flex flex-column gap-3 mb-3">
                <div>
                  <div class="cap-bar-meta" style="font-size:13px">
                    <span style="color:#6B7280">Participants: <%= event.participants_filled %> of <%= event.participant_capacity %> confirmed</span>
                    <span style="color:<%= event.participants.capColor %>"><%= event.participants.full ? ('Full · waitlist' + (event.participantWaitlistCount ? ' (' + event.participantWaitlistCount + ')' : ' available')) : (event.participants.left + ' left') %></span>
                  </div>
                  <div class="cap-bar-track" style="height:7px">
                    <div class="cap-bar-fill" style="width:<%= event.participants.pct %>%;background:<%= event.participants.capColor %>"></div>
                  </div>
                </div>
                <div>
                  <div class="cap-bar-meta" style="font-size:13px">
                    <span style="color:#6B7280">Volunteers: <%= event.volunteers_filled %> of <%= event.volunteer_capacity %> confirmed</span>
                    <span style="color:<%= event.volunteers.capColor %>"><%= event.volunteers.full ? ('Full · waitlist' + (event.volunteerWaitlistCount ? ' (' + event.volunteerWaitlistCount + ')' : ' available')) : (event.volunteers.left + ' left') %></span>
                  </div>
                  <div class="cap-bar-track" style="height:7px">
                    <div class="cap-bar-fill" style="width:<%= event.volunteers.pct %>%;background:<%= event.volunteers.capColor %>"></div>
                  </div>
                </div>
              </div>

              <%- include('partials/messages') %>

              <% if (currentRegistration && (currentRegistration.status === 'Confirmed' || currentRegistration.status === 'Waitlisted' || currentRegistration.status === 'Attended' || currentRegistration.status === 'Absent')) { %>
                <div class="d-flex flex-column gap-3">
                  <div style="font-size:15px;font-weight:700;color:#12161C">Your registration</div>
                  <div class="d-flex flex-column gap-2" style="font-size:14px">
                    <div class="d-flex justify-content-between gap-2">
                      <span class="text-muted-cc">Participation</span>
                      <span class="fw-semibold text-ink"><%= currentRegistration.participation_type %></span>
                    </div>
                    <div class="d-flex justify-content-between gap-2">
                      <span class="text-muted-cc">Status</span>
                      <span class="fw-semibold text-ink"><%= currentRegistration.status %></span>
                    </div>
                    <% if (currentRegistration.status === 'Waitlisted' && currentRegistration.waiting_position) { %>
                      <div class="d-flex justify-content-between gap-2">
                        <span class="text-muted-cc">Waiting-list position</span>
                        <span class="fw-semibold text-ink">#<%= currentRegistration.waiting_position %></span>
                      </div>
                    <% } %>
                    <% if (currentRegistration.participation_type === 'Volunteer' && currentRegistration.volunteer_role_name) { %>
                      <div class="d-flex justify-content-between gap-2">
                        <span class="text-muted-cc">Preferred role</span>
                        <span class="fw-semibold text-ink text-end"><%= currentRegistration.volunteer_role_name %></span>
                      </div>
                    <% } %>
                  </div>
                  <a href="/member/registrations" class="btn-cc btn-cc-secondary btn-cc-block">View My Registrations</a>
                  <% if (canCancelRegistration) { %>
                    <button
                      type="button"
                      class="btn-cc btn-cc-danger-outline btn-cc-block"
                      data-open-modal
                      data-event-name="<%= event.event_name %>"
                      data-cancel-registration-id="<%= currentRegistration.registration_id %>"
                    >Cancel registration</button>
                  <% } %>
                </div>
              <% } else if (canRegister) { %>
              <form id="registrationForm" method="POST" action="/events/<%= event.id %>/register" data-participation-form class="d-flex flex-column gap-3">
                <div>
                  <div class="form-label-cc mb-2">How would you like to join?</div>
                  <div class="d-flex flex-column gap-2">
                    <label class="status-option">
                      <input type="radio" name="participation_type" value="Participant" checked data-participation-type>
                      <div>
                        <div style="font-size:14px;font-weight:700;color:#12161C">Join as Participant</div>
                        <div style="font-size:12px;color:#8A93A6"><%= event.participants.full ? 'Participant places are full — join the participant waiting list' : event.participants.left + ' participant spaces remaining' %></div>
                      </div>
                    </label>
                    <label class="status-option">
                      <input type="radio" name="participation_type" value="Volunteer" data-participation-type>
                      <div>
                        <div style="font-size:14px;font-weight:700;color:#12161C">Volunteer for This Event</div>
                        <div style="font-size:12px;color:#8A93A6"><%= event.volunteers.full ? 'Volunteer places are full — join the volunteer waiting list' : event.volunteers.left + ' volunteer spaces remaining' %></div>
                      </div>
                    </label>
                  </div>
                </div>

                <div data-volunteer-role-wrap style="display:none">
                  <label class="form-label-cc" for="volunteer_role_id">Volunteer role</label>
                  <% if (roles && roles.length) { %>
                    <select class="form-select-cc" id="volunteer_role_id" name="volunteer_role_id" disabled>
                      <option value="">Select a role (optional)</option>
                      <% roles.forEach(function (r) { %>
                        <option value="<%= r.volunteer_role_id %>"><%= r.name %></option>
                      <% }) %>
                    </select>
                  <% } else { %>
                    <input type="hidden" id="volunteer_role_id" name="volunteer_role_id" value="" disabled>
                  <% } %>
                </div>

                <div>
                  <label class="form-label-cc" for="notes">Notes (optional)</label>
                  <textarea class="form-control-cc" id="notes" name="notes" rows="2" maxlength="500" placeholder="Anything the organiser should know"></textarea>
                </div>

                <button type="submit" class="btn-cc btn-cc-coral btn-cc-block btn-cc-lg" data-join-cta>Join as Participant</button>
              </form>
              <% } else { %>
                <div class="d-flex flex-column gap-2">
                  <div style="font-size:14.5px;font-weight:700;color:#12161C"><%= registrationUnavailableReason || 'Registration is not available' %></div>
                  <p class="mb-0 text-muted-cc" style="font-size:13.5px;line-height:1.55">This event cannot accept new registrations right now.</p>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <% if (canRegister) { %>
    <div class="mobile-sticky-cta">
      <a href="#registrationForm" class="btn-cc btn-cc-coral btn-cc-block">Join as Participant</a>
      <a href="#registrationForm" class="btn-cc btn-cc-outline btn-cc-block">Volunteer for This Event</a>
    </div>
    <% } else if (currentRegistration && (currentRegistration.status === 'Confirmed' || currentRegistration.status === 'Waitlisted')) { %>
    <div class="mobile-sticky-cta">
      <a href="/member/registrations" class="btn-cc btn-cc-secondary btn-cc-block">View My Registrations</a>
    </div>
    <% } %>
  </main>

  <%- include('partials/footer') %>
</div>

<form id="cancelRegistrationForm" method="POST" action="" style="display:none"></form>

<div class="modal-cc" id="confirmModal">
  <div class="modal-cc-dialog">
    <div class="modal-icon">!</div>
    <div>
      <div style="font-size:19px;font-weight:800;color:#12161C">Cancel this registration?</div>
      <div class="text-muted-cc mt-2" style="font-size:14.5px;line-height:1.55">You are about to cancel your place at <b style="color:#33394A" id="modalEventName">this event</b>. Your space will be offered to the earliest matching person on the waiting list. This cannot be undone.</div>
    </div>
    <div class="d-flex gap-2 justify-content-end">
      <button type="button" class="btn-cc btn-cc-secondary" data-close-modal>Keep my place</button>
      <button type="button" class="btn-cc btn-cc-danger" data-confirm-cancel>Yes, cancel registration</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
