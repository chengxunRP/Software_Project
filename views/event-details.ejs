<%- include('partials/header') %>
<div class="public-page">
  <%- include('partials/navbar') %>

  <main class="flex-fill">
    <div class="section-wrap" style="padding-top:32px;max-width:1120px">
      <div class="breadcrumb-cc mb-3">
        <a href="/events">Event Catalogue</a>
        <span class="sep">/</span>
        <%= event.event_name %>
      </div>

      <div class="details-grid">
        <div class="d-flex flex-column gap-4">
          <div class="page-photo">
            <span class="photo-label" style="font-family:ui-monospace,monospace;font-size:13px;color:#8B8778;background:#fff;padding:7px 12px;border-radius:8px;border:1px solid #E6E2D8"><%= event.photoLabel %></span>
          </div>

          <div>
            <div class="d-flex align-items-center gap-2 mb-2 flex-wrap">
              <span class="badge-cc badge-cc-cat" style="background:<%= event.badgeBg %>;color:<%= event.badgeFg %>"><%= event.category %></span>
              <% if (!event.full && event.pct >= 80) { %>
                <span class="badge-cc badge-cc-warning">Filling fast</span>
              <% } %>
              <% if (event.full) { %>
                <span class="badge-cc badge-cc-full">Full</span>
              <% } %>
            </div>
            <h1 class="h-page mb-2" style="font-size:34px;line-height:1.15"><%= event.event_name %></h1>
            <div class="text-muted-cc" style="font-size:14.5px">Organised by <span style="font-weight:600;color:#3C4038"><%= event.organiser %></span></div>
          </div>

          <div class="card-cc">
            <div class="card-cc-body" style="padding:24px">
              <h2 class="h-card mb-3" style="font-size:18px">About this event</h2>
              <p class="mb-0" style="font-size:15px;line-height:1.7;color:#3C4038"><%= event.description %></p>
            </div>
          </div>

          <% if (roles && roles.length) { %>
          <div class="card-cc">
            <div class="card-cc-body" style="padding:24px">
              <h2 class="h-card mb-3" style="font-size:18px">Volunteer roles</h2>
              <div class="d-flex flex-column gap-3">
                <% roles.forEach(function (r) { %>
                  <% const roleFull = r.filled >= r.capacity; %>
                  <% const roleNear = !roleFull && (r.filled / r.capacity) >= 0.8; %>
                  <div class="d-flex align-items-center justify-content-between gap-3 p-3" style="border:1px solid #E6E2D8;border-radius:11px">
                    <div>
                      <div style="font-size:15px;font-weight:700;color:#23271F"><%= r.name %></div>
                      <div style="font-size:13.5px;color:#6E7266"><%= r.description %></div>
                    </div>
                    <span class="badge-cc" style="background:<%= roleFull ? '#FBEAE8' : (roleNear ? '#FBF3DF' : '#E7F2EA') %>;color:<%= roleFull ? '#B0433B' : (roleNear ? '#8A5E08' : '#2E7D4F') %>">
                      <%= r.filled %> of <%= r.capacity %> filled
                    </span>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
          <% } %>
        </div>

        <div class="d-flex flex-column gap-3 sticky-panel hide-mobile">
          <div class="card-cc" style="border-radius:16px;box-shadow:0 2px 6px rgba(35,39,31,0.07)">
            <div class="card-cc-body" style="padding:24px">
              <div class="d-flex flex-column gap-3" style="font-size:14.5px">
                <div class="d-flex justify-content-between gap-2"><span class="text-muted-cc fw-medium">Date</span><span class="fw-semibold text-ink text-end"><%= event.dateLabel %></span></div>
                <div class="d-flex justify-content-between gap-2"><span class="text-muted-cc fw-medium">Time</span><span class="fw-semibold text-ink text-end"><%= event.timeLabel %></span></div>
                <div class="d-flex justify-content-between gap-2"><span class="text-muted-cc fw-medium">Location</span><span class="fw-semibold text-ink text-end"><%= event.location %></span></div>
                <div class="d-flex justify-content-between gap-2"><span class="text-muted-cc fw-medium">Capacity</span><span class="fw-semibold text-ink text-end"><%= event.capacity %> volunteers</span></div>
                <div class="d-flex justify-content-between gap-2"><span class="text-muted-cc fw-medium">Registration closes</span><span class="fw-semibold text-ink text-end"><%= event.deadlineLabel %></span></div>
              </div>
              <hr class="my-3" style="border-color:#EDEAE0;opacity:1">
              <div class="cap-bar mb-3">
                <div class="cap-bar-meta" style="font-size:13px">
                  <span style="color:#6E7266"><%= event.capLabel %></span>
                  <span style="color:<%= event.capColor %>"><%= event.full ? 'Full' : (event.left + ' left') %></span>
                </div>
                <div class="cap-bar-track" style="height:7px">
                  <div class="cap-bar-fill" style="width:<%= event.pct %>%;background:<%= event.capColor %>"></div>
                </div>
              </div>

              <% if (event.full) { %>
                <a href="/login" class="btn-cc btn-cc-waitlist btn-cc-block" style="padding:12px 0;border-radius:11px;font-size:14.5px">Join Waiting List</a>
                <p class="mb-0 mt-2 text-center" style="font-size:12.5px;color:#8B8778"><%= event.waitlistCount || 6 %> people currently on the waiting list. You'll be notified if a space opens up.</p>
              <% } else { %>
                <form data-preview-only class="d-flex flex-column gap-2">
                  <input type="hidden" name="event_id" value="<%= event.id %>">
                  <% if (roles && roles.length) { %>
                    <select class="form-select-cc" name="volunteer_role_id">
                      <option value="">Select a role</option>
                      <% roles.forEach(function (r) { %>
                        <option value="<%= r.volunteer_role_id %>"><%= r.name %></option>
                      <% }) %>
                    </select>
                  <% } else { %>
                    <input type="hidden" name="volunteer_role_id" value="">
                  <% } %>
                  <textarea class="form-control-cc" name="notes" rows="2" placeholder="Notes (optional)"></textarea>
                  <a href="/login" class="btn-cc btn-cc-primary btn-cc-block" style="padding:13px 0;border-radius:11px;font-weight:700;font-size:15.5px">Register for this event</a>
                </form>
                <p class="mb-0 mt-2 text-center" style="font-size:12.5px;color:#8B8778">You'll be asked to log in or create an account.</p>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="mobile-sticky-cta">
      <% if (event.full) { %>
        <a href="/login" class="btn-cc btn-cc-waitlist btn-cc-block" style="padding:14px 0;border-radius:12px;font-size:15.5px">Join Waiting List</a>
      <% } else { %>
        <a href="/login" class="btn-cc btn-cc-primary btn-cc-block" style="padding:14px 0;border-radius:12px;font-weight:700;font-size:15.5px">Register for this event</a>
      <% } %>
      <span class="text-center" style="font-size:11.5px;color:#8B8778">You'll be asked to log in or create an account.</span>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
