<% const roleLabel = role === 'member' ? 'Community member' : (role === 'organiser' ? 'Organiser' : 'Admin'); %>
<aside class="app-sidebar">
  <a href="/" class="sidebar-brand">
    <span class="brand-mark sm">C</span>
    <span class="sidebar-brand-text">CommunityConnect</span>
  </a>
  <div class="sidebar-role d-flex justify-content-between align-items-center">
    <span><%= roleLabel %></span>
    <button type="button" id="sidebarCloseBtn" class="d-lg-none border-0 bg-transparent text-white" style="font-size:18px;line-height:1" aria-label="Close menu">×</button>
  </div>

  <nav>
    <% if (role === 'member') { %>
      <a href="/member/dashboard" class="<%= activeNav === 'dashboard' ? 'active' : '' %>">Dashboard</a>
      <a href="/events" class="<%= activeNav === 'events' ? 'active' : '' %>">Browse Events</a>
      <a href="/member/registrations" class="<%= activeNav === 'registrations' ? 'active' : '' %>">My Registrations</a>
      <a href="/member/volunteer-hours" class="<%= activeNav === 'hours' ? 'active' : '' %>">Volunteer Hours</a>
      <a href="/member/profile" class="<%= activeNav === 'profile' ? 'active' : '' %>">My Profile</a>
    <% } else if (role === 'organiser') { %>
      <a href="/organiser/dashboard" class="<%= activeNav === 'dashboard' ? 'active' : '' %>">Dashboard</a>
      <a href="/organiser/events" class="<%= activeNav === 'events' ? 'active' : '' %>">Manage Events</a>
      <a href="/organiser/events/2/registrations" class="<%= activeNav === 'registrations' ? 'active' : '' %>">Registrations</a>
      <a href="/organiser/events/1/roles" class="<%= activeNav === 'roles' ? 'active' : '' %>">Role Assignment</a>
      <a href="/organiser/events/11/attendance" class="<%= activeNav === 'attendance' ? 'active' : '' %>">Attendance</a>
      <a href="/organiser/reports/attendance" class="<%= activeNav === 'attendance-reports' ? 'active' : '' %>">Attendance Reports</a>
    <% } else { %>
      <a href="/admin/dashboard" class="<%= activeNav === 'dashboard' ? 'active' : '' %>">Dashboard</a>
      <a href="/admin/users" class="<%= activeNav === 'users' ? 'active' : '' %>">User Management</a>
      <a href="/admin/categories" class="<%= activeNav === 'categories' ? 'active' : '' %>">Event Categories</a>
      <a href="/admin/reports" class="<%= activeNav === 'reports' ? 'active' : '' %>">System Reports</a>
    <% } %>
  </nav>

  <div class="sidebar-user">
    <a href="<%= role === 'member' ? '/member/profile' : (role === 'organiser' ? '/organiser/dashboard' : '/admin/dashboard') %>" class="sidebar-user-card">
      <span class="avatar-cc" style="background:<%= currentUser.avatarBg %>"><%= currentUser.initials %></span>
      <div class="min-w-0">
        <div class="name"><%= currentUser.name %></div>
        <div class="role"><%= currentUser.role %></div>
      </div>
    </a>
    <a href="/" class="sidebar-logout">Log out</a>
  </div>
</aside>
<div class="sidebar-backdrop" id="sidebarBackdrop"></div>
