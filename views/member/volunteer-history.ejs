<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <% 
    const pageEyebrow = 'Community member';
    const pageHeading = 'Volunteer history';
    const pageLead = 'Review your past volunteering events, attendance status and event categories.';
    const pageActions = '<a href="/member/volunteer-history" class="btn-cc btn-cc-primary btn-cc-sm">Refresh</a>';
  %>
  <%- include('../partials/page-header', { pageEyebrow: (typeof pageEyebrow !== 'undefined' ? pageEyebrow : ''), pageHeading: (typeof pageHeading !== 'undefined' ? pageHeading : ''), pageLead: (typeof pageLead !== 'undefined' ? pageLead : ''), pageActions: (typeof pageActions !== 'undefined' ? pageActions : '') }) %>

  <main class="site-main">
    <div class="site-content overlap-panel max-1080">
      <div class="card-cc" style="padding:24px;margin-bottom:20px">
        <form class="filter-bar card-cc" method="get" action="/member/volunteer-history" style="margin:0;box-shadow:none">
          <div>
            <label class="form-label-cc" for="search">Search</label>
            <input class="form-control-cc" type="text" id="search" name="search" value="<%= filters.search || '' %>" placeholder="Search event name">
          </div>
          <div>
            <label class="form-label-cc" for="category">Category</label>
            <select class="form-select-cc" id="category" name="category">
              <option value="">All categories</option>
              <% categories.forEach(function (cat) { %>
                <option value="<%= cat.category_id %>" <%= String(filters.category) === String(cat.category_id) ? 'selected' : '' %>><%= cat.category_name %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="form-label-cc" for="date">Event date</label>
            <input class="form-control-cc" type="date" id="date" name="date" value="<%= filters.date || '' %>">
          </div>
          <div>
            <label class="form-label-cc" for="month">Month</label>
            <select class="form-select-cc" id="month" name="month">
              <option value="">All months</option>
              <% months.forEach(function (m, index) { %>
                <option value="<%= index + 1 %>" <%= Number(filters.month) === index + 1 ? 'selected' : '' %>><%= m %></option>
              <% }) %>
            </select>
          </div>
          <div>
            <label class="form-label-cc" for="year">Year</label>
            <select class="form-select-cc" id="year" name="year">
              <option value="">All years</option>
              <% years.forEach(function (yr) { %>
                <option value="<%= yr %>" <%= Number(filters.year) === yr ? 'selected' : '' %>><%= yr %></option>
              <% }) %>
            </select>
          </div>
          <div style="display:flex;align-items:flex-end">
            <button type="submit" class="btn-cc btn-cc-primary">Apply filters</button>
          </div>
        </form>
      </div>

      <div class="table-cc">
        <div class="panel-header">
          <span class="h-card">Volunteer event history</span>
          <span class="text-muted-cc" style="font-size:13px"><%= history.length %> event<%= history.length === 1 ? '' : 's' %></span>
        </div>

        <div class="table-scroll">
          <div class="table-cc-head" style="grid-template-columns:2fr 1fr 1fr 1fr 1fr">
            <span>Event</span>
            <span>Date</span>
            <span>Category</span>
            <span>Status</span>
            <span style="text-align:right">Location</span>
          </div>

          <% if (!history.length) { %>
            <div class="p-4 text-muted-cc" style="font-size:13.5px">No volunteer history matches your filters.</div>
          <% } %>

          <% history.forEach(function (item) { %>
            <div class="table-cc-row" style="grid-template-columns:2fr 1fr 1fr 1fr 1fr">
              <div>
                <div style="font-weight:700;color:#12161C"><%= item.name %></div>
                <div class="text-muted-cc" style="font-size:13px"><%= item.meta %></div>
              </div>
              <span class="text-muted-cc"><%= item.date %></span>
              <span>
                <span class="badge-cc badge-cc-cat" style="background:<%= item.categoryBg %>;color:<%= item.categoryFg %>"><%= item.category %></span>
              </span>
              <span>
                <span class="badge-cc <%= item.badgeClass %>" style="font-size:12px;padding:4px 10px"><%= item.status %></span>
              </span>
              <span style="text-align:right;color:#12161C;font-weight:600"><%= item.location %></span>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
