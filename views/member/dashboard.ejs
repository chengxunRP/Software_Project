<%- include('../partials/header') %>
<div class="site-page app-shell clear-title-photo" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    const pageEyebrow = 'Community member';
    const pageHeading = 'Good afternoon, ' + currentUser.firstName + ' 👋';
    const pageLead = 'Join events as a Participant or Volunteer — your choice applies per event.';
    const pageActions = '<a href="/events" class="btn-cc btn-cc-primary btn-cc-sm">+ Find an event</a>';
  %>
  <%- include('../partials/page-header', { pageEyebrow: (typeof pageEyebrow !== 'undefined' ? pageEyebrow : ''), pageHeading: (typeof pageHeading !== 'undefined' ? pageHeading : ''), pageLead: (typeof pageLead !== 'undefined' ? pageLead : ''), pageActions: (typeof pageActions !== 'undefined' ? pageActions : '') }) %>

  <main class="site-main">
    <div class="site-content overlap-panel max-1080">
      <div class="row g-3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px">
        <div class="stat-card">
          <span class="stat-label">Upcoming as Participant</span>
          <span class="stat-value"><%= stats.participantUpcoming %></span>
          <span class="stat-note">Confirmed places</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Upcoming as Volunteer</span>
          <span class="stat-value green"><%= stats.volunteerUpcoming %></span>
          <span class="stat-note">Confirmed places</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Completed volunteer hours</span>
          <span class="stat-value"><%= stats.hours %></span>
          <span class="stat-note"><%= stats.hoursNote %></span>
        </div>
      </div>

      <div class="row g-3" style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px">
        <div class="stat-card">
          <span class="stat-label">Participant waiting lists</span>
          <span class="stat-value amber"><%= stats.participantWaitlist %></span>
          <span class="stat-note"><%= stats.participantWaitlist ? 'Positions shown below' : 'None right now' %></span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Volunteer waiting lists</span>
          <span class="stat-value amber"><%= stats.volunteerWaitlist %></span>
          <span class="stat-note"><%= stats.volunteerWaitlist ? 'Positions shown below' : 'None right now' %></span>
        </div>
      </div>

      <div class="dashboard-split" style="display:grid;grid-template-columns:1.4fr 1fr;gap:20px;align-items:start">
        <div class="d-flex flex-column gap-3">
          <div class="card-cc overflow-hidden">
            <div class="panel-header">
              <span class="h-card">Upcoming as Participant</span>
              <a href="/member/registrations" style="font-size:13.5px;font-weight:600">View all</a>
            </div>
            <% if (!asParticipant.length) { %>
              <div class="list-row text-muted-cc" style="font-size:13.5px">No upcoming participant places.</div>
            <% } %>
            <% asParticipant.forEach(function (r) { %>
              <div class="list-row">
                <div class="date-chip">
                  <span class="month"><%= r.month %></span>
                  <span class="day"><%= r.day %></span>
                </div>
                <div class="flex-fill min-w-0">
                  <div style="font-size:15px;font-weight:700;color:#12161C"><%= r.name %></div>
                  <div style="font-size:13px;color:#6B7280"><%= r.meta %></div>
                </div>
                <span class="badge-cc" style="background:#E9EDF6;color:#3B5384">Participant</span>
              </div>
            <% }) %>
          </div>

          <div class="card-cc overflow-hidden">
            <div class="panel-header">
              <span class="h-card">Upcoming as Volunteer</span>
              <a href="/member/registrations" style="font-size:13.5px;font-weight:600">View all</a>
            </div>
            <% if (!asVolunteer.length) { %>
              <div class="list-row text-muted-cc" style="font-size:13.5px">No upcoming volunteer places.</div>
            <% } %>
            <% asVolunteer.forEach(function (r) { %>
              <div class="list-row">
                <div class="date-chip">
                  <span class="month"><%= r.month %></span>
                  <span class="day"><%= r.day %></span>
                </div>
                <div class="flex-fill min-w-0">
                  <div style="font-size:15px;font-weight:700;color:#12161C"><%= r.name %></div>
                  <div style="font-size:13px;color:#6B7280"><%= r.meta %></div>
                </div>
                <span class="badge-cc" style="background:#E8F7F0;color:#056047">Volunteer</span>
              </div>
            <% }) %>
          </div>

          <div class="card-cc overflow-hidden">
            <div class="panel-header">
              <span class="h-card">Waiting-list positions</span>
            </div>
            <% participantWaitlist.forEach(function (r) { %>
              <div class="list-row">
                <div class="date-chip amber">
                  <span class="month"><%= r.month %></span>
                  <span class="day"><%= r.day %></span>
                </div>
                <div class="flex-fill min-w-0">
                  <div style="font-size:15px;font-weight:700;color:#12161C"><%= r.name %></div>
                  <div style="font-size:13px;color:#6B7280">Participant · <%= r.note || r.meta %></div>
                </div>
                <span class="badge-cc" style="background:<%= r.badgeBg %>;color:<%= r.badgeFg %>"><%= r.badge %></span>
              </div>
            <% }) %>
            <% volunteerWaitlist.forEach(function (r) { %>
              <div class="list-row">
                <div class="date-chip amber">
                  <span class="month"><%= r.month %></span>
                  <span class="day"><%= r.day %></span>
                </div>
                <div class="flex-fill min-w-0">
                  <div style="font-size:15px;font-weight:700;color:#12161C"><%= r.name %></div>
                  <div style="font-size:13px;color:#6B7280">Volunteer · <%= r.note || r.meta %></div>
                </div>
                <span class="badge-cc" style="background:<%= r.badgeBg %>;color:<%= r.badgeFg %>"><%= r.badge %></span>
              </div>
            <% }) %>
            <% if (!participantWaitlist.length && !volunteerWaitlist.length) { %>
              <div class="list-row text-muted-cc" style="font-size:13.5px">You are not on any waiting lists.</div>
            <% } %>
          </div>

          <div class="card-cc overflow-hidden">
            <div class="panel-header">
              <span class="h-card">Recommended for you</span>
              <a href="/events" style="font-size:13.5px;font-weight:600">Browse all</a>
            </div>
            <% recommended.forEach(function (ev) { %>
              <div class="list-row">
                <span class="badge-cc badge-cc-cat" style="background:<%= ev.badgeBg %>;color:<%= ev.badgeFg %>"><%= ev.category %></span>
                <div class="flex-fill min-w-0">
                  <div style="font-size:14px;font-weight:600;color:#12161C"><%= ev.event_name %></div>
                  <div style="font-size:12.5px;color:#6B7280"><%= ev.when.split(' · ')[0] %> · P <%= ev.participants.left %> left · V <%= ev.volunteers.left %> left</div>
                </div>
                <a href="/events/<%= ev.id %>" style="font-size:13px;font-weight:600;flex-shrink:0">View →</a>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="card-cc overflow-hidden">
          <div class="panel-header">
            <span class="h-card">Recent notifications</span>
            <form method="POST" action="/member/notifications/read-all">
              <button type="submit" class="btn-cc btn-cc-secondary btn-cc-xs">Mark all read</button>
            </form>
          </div>
          <% if (!notifications.length) { %>
            <div class="list-row">
              <div class="text-muted-cc" style="font-size:13.5px">No notifications are available.</div>
            </div>
          <% } %>
          <% notifications.forEach(function (n) { %>
            <div class="list-row align-items-start">
              <span class="notif-dot <%= n.type %>"></span>
              <div class="flex-fill min-w-0">
                <div style="font-size:13.5px;color:#12161C;line-height:1.45;font-weight:<%= n.is_read ? '500' : '700' %>"><%- n.text %></div>
                <div style="font-size:12px;color:#8A93A6"><%= n.time %><%= n.is_read ? '' : ' · Unread' %></div>
              </div>
              <% if (!n.is_read) { %>
                <form method="POST" action="/member/notifications/<%= n.id %>/read">
                  <button type="submit" class="btn-cc btn-cc-secondary btn-cc-xs">Mark read</button>
                </form>
              <% } %>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
