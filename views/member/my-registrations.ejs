<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    const pageEyebrow = 'Community member';
    const pageHeading = 'My Registrations';
    const pageLead = 'Track your participant and volunteer registrations, waiting-list positions and cancellations.';
    const pageActions = '<a href="/events" class="btn-cc btn-cc-primary btn-cc-sm">+ Find an event</a>';
  %>
  <%- include('../partials/page-header', { pageEyebrow: (typeof pageEyebrow !== 'undefined' ? pageEyebrow : ''), pageHeading: (typeof pageHeading !== 'undefined' ? pageHeading : ''), pageLead: (typeof pageLead !== 'undefined' ? pageLead : ''), pageActions: (typeof pageActions !== 'undefined' ? pageActions : '') }) %>

  <main class="site-main">
    <div class="site-content overlap-panel max-1000">
      <%- include('../partials/messages') %>

      <div class="tabs-cc">
        <% tabs.forEach(function (tab) { %>
          <a href="/member/registrations?tab=<%= tab %>" class="<%= activeTab === tab ? 'active' : '' %>"><%= tab %> (<%= tabCounts[tab] %>)</a>
        <% }) %>
      </div>

      <div class="d-flex flex-column gap-3">
        <% if (!rows.length) { %>
          <div class="empty-state">
            <div style="width:52px;height:52px;border-radius:50%;background:#E2E6ED;display:flex;align-items:center;justify-content:center;font-size:22px">🗂</div>
            <div style="font-size:16px;font-weight:700;color:#12161C">Nothing here yet</div>
            <div class="text-muted-cc" style="font-size:14px;max-width:36ch">No registrations in this category. Browse the catalogue to join as a Participant or Volunteer.</div>
            <a href="/events" class="btn-cc btn-cc-primary mt-2">Browse Events</a>
          </div>
        <% } %>

        <% rows.forEach(function (r) { %>
          <div class="card-cc" style="padding:20px;display:flex;align-items:center;gap:16px;flex-wrap:wrap">
            <div class="date-chip <%= r.tone === 'amber' ? 'amber' : (r.tone === 'grey' ? 'grey' : '') %>" style="width:54px;height:54px;border-radius:12px">
              <span class="month"><%= r.month %></span>
              <span class="day" style="font-size:20px"><%= r.day %></span>
            </div>
            <div class="flex-fill min-w-0">
              <div style="font-size:15.5px;font-weight:700;color:#12161C"><%= r.name %></div>
              <div style="font-size:13.5px;color:#6B7280;margin-top:2px">
                <span style="font-weight:600;color:#33394A"><%= r.participation_type %></span>
                · <%= r.meta %>
              </div>
              <% if (r.waiting_position) { %>
                <div style="font-size:12.5px;color:#8A6008;font-weight:600;margin-top:2px">Waiting-list position: #<%= r.waiting_position %></div>
              <% } %>
              <% if (r.registered_label) { %>
                <div style="font-size:12.5px;color:#8A93A6;margin-top:2px">Registered: <%= r.registered_label %></div>
              <% } %>
              <% if (r.note) { %>
                <div style="font-size:12.5px;color:#8A6008;font-weight:600"><%= r.note %></div>
              <% } %>
            </div>
            <div class="d-flex flex-column align-items-end gap-1">
              <span class="badge-cc" style="background:<%= r.participation_type === 'Volunteer' ? '#E8F7F0' : '#E9EDF6' %>;color:<%= r.participation_type === 'Volunteer' ? '#056047' : '#3B5384' %>"><%= r.participation_type %></span>
              <span class="badge-cc" style="background:<%= r.badgeBg %>;color:<%= r.badgeFg %>"><%= r.badge %></span>
            </div>
            <div class="d-flex gap-2">
              <a href="/events/<%= r.eventId %>" class="btn-cc btn-cc-secondary btn-cc-sm">View</a>
              <% if (r.cancellable) { %>
                <button type="button" class="btn-cc btn-cc-danger-outline btn-cc-sm" data-open-modal data-event-name="<%= r.name %>" data-cancel-registration-id="<%= r.registration_id %>">Cancel</button>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>

<form id="cancelRegistrationForm" method="POST" action="" style="display:none"></form>

<div class="modal-cc" id="confirmModal">
  <div class="modal-cc-dialog">
    <div class="modal-icon">!</div>
    <div>
      <div style="font-size:19px;font-weight:800;color:#12161C">Cancel this registration?</div>
      <div class="text-muted-cc mt-2" style="font-size:14.5px;line-height:1.55">You are about to cancel your place at <b style="color:#33394A" id="modalEventName">this event</b>. Your space will be offered to the earliest matching person on the waiting list. This cannot be undone.</div>
    </div>
    <div class="d-flex gap-2 justify-content-end">
      <button type="button" class="btn-cc btn-cc-secondary" data-close-modal>Keep my place</button>
      <button type="button" class="btn-cc btn-cc-danger" data-confirm-cancel>Yes, cancel registration</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
