<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    pageEyebrow = 'Community member';
    pageHeading = 'My Profile';
    pageLead = 'Manage your personal account details.';
    pageActions = '';
  %>
  <%- include('../partials/page-header') %>

  <main class="site-main">
    <div class="site-content overlap-panel max-1000">
      <div class="dashboard-split" style="display:grid;grid-template-columns:1fr 1fr;gap:20px;align-items:start">
        <div class="card-cc" style="padding:26px">
          <div class="d-flex align-items-center gap-3 mb-4">
            <span class="avatar-cc" style="width:56px;height:56px;font-size:18px;background:<%= profile.avatarBg %>"><%= profile.initials %></span>
            <div>
              <div style="font-size:20px;font-weight:800;color:#23271F"><%= profile.name %></div>
              <div class="text-muted-cc"><%= profile.role %></div>
            </div>
          </div>

          <form data-preview-only class="d-flex flex-column gap-3">
            <div>
              <label class="form-label-cc" for="full_name">Full name</label>
              <input class="form-control-cc" type="text" id="full_name" name="full_name" value="<%= profile.name %>">
            </div>
            <div>
              <label class="form-label-cc" for="email">Email address</label>
              <input class="form-control-cc" type="email" id="email" name="email" value="<%= profile.email %>">
            </div>
            <div>
              <label class="form-label-cc" for="mobile">Mobile number</label>
              <input class="form-control-cc" type="tel" id="mobile" name="mobile" value="<%= profile.mobile %>">
            </div>
            <button type="submit" class="btn-cc btn-cc-primary align-self-start">Save changes</button>
          </form>
        </div>

        <div class="d-flex flex-column gap-3">
          <div class="stat-card">
            <span class="stat-label">Member since</span>
            <span class="stat-value" style="font-size:24px"><%= profile.joined %></span>
            <span class="stat-note">Account preview — no backend save yet</span>
          </div>
          <div class="stat-card">
            <span class="stat-label">Completed hours</span>
            <span class="stat-value green"><%= hours %></span>
            <span class="stat-note">Across <%= attendedEvents %> attended events</span>
          </div>
          <div class="card-cc" style="padding:20px">
            <div class="h-card mb-2">Quick links</div>
            <div class="d-flex flex-column gap-2">
              <a href="/member/registrations" style="font-weight:600">My Registrations →</a>
              <a href="/member/volunteer-hours" style="font-weight:600">My Volunteer Hours →</a>
              <a href="/events" style="font-weight:600">Browse Events →</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
