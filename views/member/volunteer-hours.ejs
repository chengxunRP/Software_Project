<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    const pageEyebrow = 'Community member';
    const pageHeading = 'My Volunteer Hours';
    const pageLead = 'Hours earned when you volunteered, tracked by month and by event.';
    const pageActions = '';
  %>
  <%- include('../partials/page-header', { pageEyebrow: (typeof pageEyebrow !== 'undefined' ? pageEyebrow : ''), pageHeading: (typeof pageHeading !== 'undefined' ? pageHeading : ''), pageLead: (typeof pageLead !== 'undefined' ? pageLead : ''), pageActions: (typeof pageActions !== 'undefined' ? pageActions : '') }) %>

  <main class="site-main">
    <div class="site-content overlap-panel max-1000">
      <div class="dashboard-split" style="display:grid;grid-template-columns:1.2fr 1fr 1fr;gap:16px">
        <div style="background:#0B2A20;border-radius:16px;padding:24px;display:flex;flex-direction:column;gap:6px">
          <span style="font-size:13px;font-weight:600;color:#9FCDBB">Total completed hours</span>
          <span style="font-size:42px;font-weight:800;color:#fff;letter-spacing:-0.02em;line-height:1"><%= summary.totalHours %></span>
          <span style="font-size:13px;color:#6FA391">Across <%= summary.eventCount %> attended events since January <%= summary.chartYear %></span>
        </div>
        <div class="stat-card" style="border-radius:16px;padding:24px">
          <span class="stat-label">This month (<%= summary.monthLabel %>)</span>
          <span class="stat-value green" style="font-size:32px"><%= summary.monthHours %></span>
          <span class="stat-note"><%= summary.monthEvents %> events attended</span>
        </div>
        <div class="stat-card" style="border-radius:16px;padding:24px">
          <span class="stat-label">Attendance rate</span>
          <span class="stat-value" style="font-size:32px"><%= summary.attendanceRate %></span>
          <span class="stat-note"><%= summary.attended %> attended · <%= summary.absent %> absent</span>
        </div>
      </div>

      <div class="table-cc">
        <div class="panel-header">
          <span class="h-card">Event history</span>
        </div>
        <div class="table-scroll">
          <div class="table-cc-head" style="grid-template-columns:2.2fr 1.1fr 1.3fr 0.9fr 0.8fr">
            <span>Event</span><span>Date</span><span>Location</span><span>Status</span><span style="text-align:right">Hours</span>
          </div>
          <% if (!history.length) { %>
            <div class="p-4 text-muted-cc" style="font-size:13.5px">No Volunteer hours have been completed.</div>
          <% } %>
          <% history.forEach(function (h) { %>
            <div class="table-cc-row" style="grid-template-columns:2.2fr 1.1fr 1.3fr 0.9fr 0.8fr">
              <span style="font-weight:600;color:#12161C"><%= h.name %></span>
              <span class="text-muted-cc"><%= h.date %></span>
              <span class="text-muted-cc"><%= h.loc %></span>
              <span>
                <span class="badge-cc <%= h.status === 'Absent' ? 'badge-cc-absent' : 'badge-cc-attended' %>" style="font-size:11.5px;padding:4px 10px"><%= h.status %></span>
              </span>
              <span style="text-align:right;font-weight:700;color:#12161C"><%= h.hours %></span>
            </div>
          <% }) %>
          <div class="d-flex justify-content-end p-3" style="font-size:14px;font-weight:700;color:#12161C;background:#E8F7F0">
            Total &nbsp;<span style="color:#087F5B"><%= summary.totalHours %> hours</span>
          </div>
        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
