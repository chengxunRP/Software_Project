<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    pageEyebrow = 'Organiser';
    pageHeading = event.event_name;
    pageLead = event.category_name;
  %>
  <%- include('../partials/page-header') %>

  <main class="site-main">
    <div class="site-content overlap-panel max-1060">
      <%- include('../partials/messages') %>

      <div class="details-grid" style="grid-template-columns:1fr 320px">
        <div class="d-flex flex-column gap-3">
          <div class="card-cc" style="border-radius:16px;padding:26px">
            <div class="h-card mb-3" style="font-size:15px">Event details</div>
            <div class="mb-3">
              <div style="font-size:15px;font-weight:700;color:#23271F">Description</div>
              <p class="text-muted-cc mt-2" style="font-size:14.5px;line-height:1.8"><%= event.description %></p>
            </div>
            <div class="form-grid-2 mb-3">
              <div>
                <div class="form-label-cc">Category</div>
                <div><%= event.category_name %></div>
              </div>
              <div>
                <div class="form-label-cc">Status</div>
                <span class="badge-cc <%= event.status === 'Draft' ? 'badge-cc-draft' : (event.status === 'Open' ? 'badge-cc-success' : (event.status === 'Full' ? 'badge-cc-warning' : (event.status === 'Cancelled' ? 'badge-cc-danger' : (event.status === 'Completed' ? 'badge-cc-completed' : 'badge-cc-muted')))) %>" style="font-size:12.5px"><%= event.status %></span>
              </div>
            </div>
            <div class="form-grid-2 mb-3">
              <div>
                <div class="form-label-cc">Location</div>
                <div><%= event.location %></div>
              </div>
              <div>
                <div class="form-label-cc">Capacity</div>
                <div style="font-size:14px;color:#23271F">Participants: <%= event.participants_filled %> / <%= event.participant_capacity %><br>Volunteers: <%= event.volunteers_filled %> / <%= event.volunteer_capacity %></div>
              </div>
            </div>
            <div class="form-grid-2">
              <div>
                <div class="form-label-cc">Start</div>
                <div><%= new Date(event.start_datetime).toLocaleString('en-GB', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></div>
              </div>
              <div>
                <div class="form-label-cc">End</div>
                <div><%= new Date(event.end_datetime).toLocaleString('en-GB', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></div>
              </div>
            </div>
          </div>
        </div>

        <div class="d-flex flex-column gap-3 sticky-panel">
          <div class="card-cc" style="border-radius:16px;padding:22px">
            <div class="h-card mb-3" style="font-size:15px">Quick summary</div>
            <div class="d-flex flex-column gap-3">
              <div>
                <div class="form-label-cc">Registration deadline</div>
                <div><%= new Date(event.registration_deadline).toLocaleString('en-GB', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) %></div>
              </div>
              <div>
                <div class="form-label-cc">Confirmed participants</div>
                <div><%= event.participants_filled %> of <%= event.participant_capacity %></div>
              </div>
              <div>
                <div class="form-label-cc">Confirmed volunteers</div>
                <div><%= event.volunteers_filled %> of <%= event.volunteer_capacity %></div>
              </div>
            </div>
          </div>
          <div class="card-cc" style="border-radius:16px;padding:22px">
            <div class="d-flex gap-2">
              <a href="/organiser/events/<%= event.event_id %>/edit" class="btn-cc btn-cc-secondary btn-cc-block">Edit event</a>
              <button type="button" class="btn-cc btn-cc-danger btn-cc-block" data-open-modal data-delete-event-id="<%= event.event_id %>" data-event-name="<%= event.event_name %>">Delete event</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
</div>

<form id="deleteEventForm" method="POST" action="" style="display:none"></form>
<div class="modal-cc" id="confirmModal">
  <div class="modal-cc-dialog" style="width:460px">
    <div class="modal-icon">!</div>
    <div>
      <div style="font-size:19px;font-weight:800;color:#23271F">Delete this event?</div>
      <div class="text-muted-cc mt-2" style="font-size:14.5px;line-height:1.55">This will remove <b id="modalEventName">this event</b> and all associated registrations. This cannot be undone.</div>
    </div>
    <div class="d-flex gap-2 justify-content-end">
      <button type="button" class="btn-cc btn-cc-secondary" data-close-modal>Keep event</button>
      <button type="button" class="btn-cc btn-cc-danger" data-confirm-delete>Yes, delete event</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
