<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    pageEyebrow = 'Organiser';
    pageHeading = 'Add Event';
    pageLead = 'Create a new community event and set separate participant and volunteer capacities.';
  %>
  <%- include('../partials/page-header') %>

  <main class="site-main">
    <div class="site-content overlap-panel max-1060">
      <%- include('../partials/messages') %>

      <form method="POST" action="/organiser/events" class="details-grid" style="grid-template-columns:1fr 320px">
        <div class="d-flex flex-column gap-3">
          <div class="card-cc" style="border-radius:16px;padding:26px">
            <div class="h-card mb-3" style="font-size:15px">Event details</div>
            <div class="mb-3">
              <label class="form-label-cc" for="event_name">Event name <span class="req">*</span></label>
              <input class="form-control-cc" type="text" id="event_name" name="event_name" value="<%= event.event_name %>">
            </div>
            <div class="form-grid-2 mb-3">
              <div>
                <label class="form-label-cc" for="category_id">Category <span class="req">*</span></label>
                <select class="form-select-cc" id="category_id" name="category_id">
                  <option value="">Select category</option>
                  <% categories.forEach(function (category) { %>
                    <option value="<%= category.category_id %>" <%= String(event.category_id) === String(category.category_id) ? 'selected' : '' %>><%= category.name %></option>
                  <% }) %>
                </select>
              </div>
              <div>
                <label class="form-label-cc" for="location">Location <span class="req">*</span></label>
                <input class="form-control-cc" type="text" id="location" name="location" value="<%= event.location %>">
              </div>
            </div>
            <div>
              <label class="form-label-cc" for="description">Description <span class="req">*</span></label>
              <textarea class="form-control-cc" id="description" name="description" rows="5"><%= event.description %></textarea>
            </div>
          </div>

          <div class="card-cc" style="border-radius:16px;padding:26px">
            <div class="h-card mb-3" style="font-size:15px">Schedule & capacity</div>
            <div class="form-grid-2 mb-3">
              <div>
                <label class="form-label-cc" for="start_datetime">Start date & time <span class="req">*</span></label>
                <input class="form-control-cc" type="datetime-local" id="start_datetime" name="start_datetime" value="<%= event.start_datetime %>">
              </div>
              <div>
                <label class="form-label-cc" for="end_datetime">End date & time <span class="req">*</span></label>
                <input class="form-control-cc" type="datetime-local" id="end_datetime" name="end_datetime" value="<%= event.end_datetime %>">
              </div>
            </div>
            <div class="form-grid-2 mb-3">
              <div>
                <label class="form-label-cc" for="participant_capacity">Participant capacity <span class="req">*</span></label>
                <input class="form-control-cc" type="number" id="participant_capacity" name="participant_capacity" min="1" value="<%= event.participant_capacity %>">
              </div>
              <div>
                <label class="form-label-cc" for="volunteer_capacity">Volunteer capacity <span class="req">*</span></label>
                <input class="form-control-cc" type="number" id="volunteer_capacity" name="volunteer_capacity" min="1" value="<%= event.volunteer_capacity %>">
              </div>
            </div>
            <div>
              <label class="form-label-cc" for="registration_deadline">Registration deadline <span class="req">*</span></label>
              <input class="form-control-cc" type="datetime-local" id="registration_deadline" name="registration_deadline" value="<%= event.registration_deadline %>">
            </div>
          </div>
        </div>

        <div class="d-flex flex-column gap-3 sticky-panel">
          <div class="card-cc" style="border-radius:16px;padding:22px">
            <div class="h-card mb-3" style="font-size:15px">Event status</div>
            <div class="d-flex flex-column gap-2">
              <% statusOptions.forEach(function (option) { %>
                <label class="status-option <%= event.status === option.value ? 'active' : '' %>">
                  <input type="radio" name="status" value="<%= option.value %>" <%= event.status === option.value ? 'checked' : '' %>>
                  <div>
                    <div style="font-size:14px;font-weight:700;color:<%= event.status === option.value ? '#1E4D33' : '#23271F' %>"><%= option.label %></div>
                  </div>
                </label>
              <% }) %>
            </div>
          </div>

          <div class="card-cc" style="border-radius:16px;padding:22px">
            <div class="h-card mb-3" style="font-size:15px">Quick checklist</div>
            <div class="text-muted-cc" style="font-size:14px;line-height:1.7">
              Ensure event details are correct before publishing. Organisers can edit the event again later if the schedule changes.
            </div>
          </div>
        </div>
      </form>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
