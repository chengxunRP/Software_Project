<%- include('partials/header') %>
<div class="site-page public-page">
  <%- include('partials/navbar') %>

  <section class="hero-section">
    <div class="hero-inner">
      <div class="hero-copy">
        <div class="hero-badge">
          <span class="dot"></span>
          <%= typeof heroBadge !== 'undefined' ? heroBadge : 'Community events across Singapore' %>
        </div>
        <h1 class="hero-title">Lend a hand where it matters — right in your neighbourhood.</h1>
        <p class="hero-lead">CommunityConnect SG links community members with local organisations across Singapore. Join an event as a Participant or Volunteer, and track the hours you contribute when you help.</p>
        <div class="hero-actions">
          <a href="/events" class="btn-cc btn-cc-primary btn-cc-lg">Browse Events</a>
          <a href="/register" class="btn-cc btn-cc-secondary btn-cc-lg">Create an account</a>
        </div>
      </div>
      <div class="hero-visual">
        <span class="hero-visual-emoji" aria-hidden="true">🌿</span>
      </div>
    </div>
  </section>

  <section id="impact" class="impact-section">
    <div class="impact-inner">
      <div class="impact-stat">
        <div class="value"><%= impactStats.activeMembers %></div>
        <div class="label">Active community members</div>
      </div>
      <div class="impact-stat">
        <div class="value"><%= impactStats.eventsHosted %></div>
        <div class="label">Events hosted</div>
      </div>
      <div class="impact-stat">
        <div class="value"><%= impactStats.volunteerHours %></div>
        <div class="label">Volunteer hours recorded</div>
      </div>
      <div class="impact-stat">
        <div class="value"><%= impactStats.activeOrganisers %></div>
        <div class="label">Active <%= impactStats.activeOrganisers === 1 ? 'organiser' : 'organisers' %></div>
      </div>
    </div>
  </section>

  <section>
    <div class="section-wrap">
      <div class="d-flex align-items-end justify-content-between mb-4 flex-wrap gap-2">
        <div>
          <h2 class="h-section mb-1">Featured upcoming events</h2>
          <p class="mb-0 text-muted-cc">Sign up early — popular events fill up fast.</p>
        </div>
        <a href="/events" style="font-weight:700;font-size:15px">View all events →</a>
      </div>

      <% if (!featuredEvents || !featuredEvents.length) { %>
        <div class="card-cc" style="padding:28px">
          <div style="font-size:16px;font-weight:700;color:#17342C">No upcoming events are currently available.</div>
          <div class="text-muted-cc mt-1">Check back soon or browse the full catalogue for other events.</div>
          <a href="/events" class="btn-cc btn-cc-primary mt-3">Browse Events</a>
        </div>
      <% } else { %>
        <div class="row g-4 events-grid">
          <% featuredEvents.forEach(function (ev) { %>
            <div class="col-md-6 col-lg-4">
              <div class="event-card">
                <%- include('partials/event-card-panel', { category: ev.category }) %>
                <div class="event-card-body">
                  <span class="badge-cc badge-cc-cat align-self-start" style="background:<%= ev.badgeBg %>;color:<%= ev.badgeFg %>"><%= ev.category %></span>
                  <div class="event-card-title"><%= ev.event_name %></div>
                  <div class="event-card-meta">
                    <span><%= ev.when %></span>
                    <span><%= ev.location %></span>
                  </div>
                  <div class="mt-auto">
                    <div class="cap-bar">
                      <div class="cap-bar-meta">
                        <span>Participants <%= ev.participants_filled %>/<%= ev.participant_capacity %></span>
                        <span style="color:<%= ev.participants.capColor %>"><%= ev.participants.full ? 'Waitlist' : (ev.participants.left + ' left') %></span>
                      </div>
                      <div class="cap-bar-track">
                        <div class="cap-bar-fill" style="width:<%= ev.participants.pct %>%;background:<%= ev.participants.capColor %>"></div>
                      </div>
                    </div>
                    <div class="cap-bar mt-2">
                      <div class="cap-bar-meta">
                        <span>Volunteers <%= ev.volunteers_filled %>/<%= ev.volunteer_capacity %></span>
                        <span style="color:<%= ev.volunteers.capColor %>"><%= ev.volunteers.full ? 'Waitlist' : (ev.volunteers.left + ' left') %></span>
                      </div>
                      <div class="cap-bar-track">
                        <div class="cap-bar-fill" style="width:<%= ev.volunteers.pct %>%;background:<%= ev.volunteers.capColor %>"></div>
                      </div>
                    </div>
                    <a href="/events/<%= ev.id %>" class="btn-cc btn-cc-outline btn-cc-block mt-3">View Details</a>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>

  <section id="how" class="how-section">
    <div class="section-wrap">
      <div class="text-center mb-4">
        <div class="page-eyebrow centered">How it works</div>
        <h2 class="h-section">One account. Every way to take part.</h2>
        <p class="text-muted-cc">Create a Community Member account, then choose Participant or Volunteer for each event.</p>
      </div>
      <div class="how-grid">
        <div class="how-step">
          <div class="how-num">1</div>
          <h3>Create your account</h3>
          <p>Register once as a Community Member — no separate Participant or Volunteer accounts needed.</p>
        </div>
        <div class="how-step">
          <div class="how-num">2</div>
          <h3>Choose how to join</h3>
          <p>On each event, pick Join as Participant or Volunteer for This Event. Capacities are tracked separately.</p>
        </div>
        <div class="how-step">
          <div class="how-num">3</div>
          <h3>Show up and contribute</h3>
          <p>Attend as a participant, or help as a volunteer and earn verified hours for the shifts you complete.</p>
        </div>
      </div>

      <div class="twin-cards mt-4">
        <div class="twin-card participant">
          <div class="twin-card-head">
            <div class="twin-card-icon">🙋</div>
            <div class="twin-card-title">Join as a Participant</div>
          </div>
          <p>Take part in activities, workshops and community programmes. Ideal when you want to attend and enjoy the event.</p>
          <a href="/events">Browse events →</a>
        </div>
        <div class="twin-card volunteer">
          <div class="twin-card-head">
            <div class="twin-card-icon">🤝</div>
            <div class="twin-card-title">Help as a Volunteer</div>
          </div>
          <p>Support organisers with roles like packing, befriending or tutoring. Volunteer hours are recorded when you attend.</p>
          <a href="/events">Find volunteer places →</a>
        </div>
      </div>
    </div>
  </section>

  <section id="categories" class="categories-section">
    <div class="section-wrap">
      <div class="text-center mb-4">
        <div class="page-eyebrow centered">Explore</div>
        <h2 class="h-section">Browse by category</h2>
      </div>
      <div class="category-grid">
        <a href="/events?category=1" class="category-tile"><span class="icon">🌿</span><span>Environment</span></a>
        <a href="/events?category=2" class="category-tile"><span class="icon">🍲</span><span>Food Support</span></a>
        <a href="/events?category=3" class="category-tile"><span class="icon">🤝</span><span>Elderly Support</span></a>
        <a href="/events?category=4" class="category-tile"><span class="icon">📚</span><span>Education</span></a>
        <a href="/events?category=5" class="category-tile"><span class="icon">💛</span><span>Fundraising</span></a>
        <a href="/events" class="category-tile"><span class="icon">💚</span><span>All events</span></a>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="cta-band-inner">
      <div>
        <h2>Ready to join your neighbourhood?</h2>
        <p>Browse open events, join as a Participant or Volunteer, and start making a difference this week.</p>
      </div>
      <div class="cta-band-actions">
        <a href="/events" class="btn-cc btn-cc-primary">Browse Events</a>
        <a href="/register" class="btn-cc btn-cc-secondary">Create an account</a>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
