<%- include('partials/header') %>
<div class="public-page">
  <%- include('partials/navbar') %>

  <section class="hero-section">
    <div class="hero-inner">
      <div class="d-flex flex-column gap-3">
        <div class="hero-badge">
          <span class="dot"></span>
          <%= heroBadge %>
        </div>
        <h1 class="hero-title">Lend a hand where it matters — right in your neighbourhood.</h1>
        <p class="hero-lead">CommunityConnect SG links volunteers with community organisations across Singapore. Find an event, sign up in minutes, and track every hour you contribute.</p>
        <div class="hero-actions">
          <a href="/events" class="btn-cc btn-cc-primary btn-cc-lg">Browse Events</a>
          <a href="/register" class="btn-cc btn-cc-secondary btn-cc-lg">Become a Volunteer</a>
        </div>
      </div>
      <div class="hero-visual">
        <span class="photo-label" style="font-family:ui-monospace,monospace;font-size:13px;color:#8B8778;background:#fff;padding:8px 14px;border-radius:8px;border:1px solid #E6E2D8">photo: volunteers at East Coast Park clean-up</span>
      </div>
    </div>
  </section>

  <section id="impact" class="impact-section">
    <div class="impact-inner">
      <div class="impact-stat">
        <div class="value"><%= impactStats.activeVolunteers %></div>
        <div class="label">Active volunteers</div>
      </div>
      <div class="impact-stat">
        <div class="value"><%= impactStats.eventsHosted %></div>
        <div class="label">Events hosted</div>
      </div>
      <div class="impact-stat">
        <div class="value"><%= impactStats.volunteerHours %></div>
        <div class="label">Volunteer hours recorded</div>
      </div>
      <div class="impact-stat">
        <div class="value"><%= impactStats.partnerOrgs %></div>
        <div class="label">Partner organisations</div>
      </div>
    </div>
  </section>

  <section>
    <div class="section-wrap">
      <div class="d-flex align-items-end justify-content-between mb-4 flex-wrap gap-2">
        <div>
          <h2 class="h-section mb-1" style="font-size:28px">Featured upcoming events</h2>
          <p class="mb-0 text-muted-cc">Sign up early — popular events fill up fast.</p>
        </div>
        <a href="/events" style="font-weight:600;font-size:15px">View all events →</a>
      </div>

      <div class="row g-4 events-grid">
        <% featuredEvents.forEach(function (ev) { %>
          <div class="col-md-6 col-lg-4">
            <div class="event-card">
              <div class="event-card-photo">
                <span class="photo-label"><%= ev.photoLabel %></span>
              </div>
              <div class="event-card-body">
                <span class="badge-cc badge-cc-cat align-self-start" style="background:<%= ev.badgeBg %>;color:<%= ev.badgeFg %>"><%= ev.category %></span>
                <div class="event-card-title"><%= ev.event_name %></div>
                <div class="event-card-meta">
                  <span><%= ev.when %></span>
                  <span><%= ev.location %></span>
                </div>
                <div class="mt-auto">
                  <div class="cap-bar">
                    <div class="cap-bar-meta">
                      <span style="color:#6E7266"><%= ev.capLabel %></span>
                      <span style="color:<%= ev.capColor %>"><%= ev.capNote %></span>
                    </div>
                    <div class="cap-bar-track">
                      <div class="cap-bar-fill" style="width:<%= ev.pct %>%;background:<%= ev.capColor %>"></div>
                    </div>
                  </div>
                  <a href="/events/<%= ev.id %>" class="btn-cc btn-cc-outline btn-cc-block mt-3">View Details</a>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
