<%- include('partials/header') %>
<div class="site-page public-page">
  <%- include('partials/navbar') %>

  <main class="auth-split">
    <aside class="auth-split-panel">
      <div class="auth-split-brand">
        <span class="brand-mark">C</span>
        <span class="brand-name light">CommunityConnect <span class="sg">SG</span></span>
      </div>
        <h2>Choose a new password.</h2>
      <p>Pick something memorable that only you know. Use at least 8 characters.</p>
      <ul class="auth-benefit-list">
        <li>Your new password is stored securely</li>
        <li>This reset link works once</li>
        <li>You can log in straight away</li>
      </ul>
    </aside>

    <div class="auth-split-form">
      <div class="auth-split-form-inner">
        <h2 class="h-page" style="font-size:28px">Reset your password</h2>
        <p class="text-muted-cc mb-4">Enter a new password for your CommunityConnect SG account.</p>

        <%- include('partials/messages') %>

        <form class="auth-card flat" method="POST" action="/reset-password">
          <input type="hidden" name="token" value="<%= typeof token !== 'undefined' ? token : '' %>">
          <div>
            <label class="form-label-cc" for="password">New password</label>
            <input class="form-control-cc" type="password" id="password" name="password" autocomplete="new-password" required minlength="8" placeholder="Min. 8 characters">
          </div>
          <div>
            <label class="form-label-cc" for="confirm_password">Confirm new password</label>
            <input class="form-control-cc" type="password" id="confirm_password" name="confirm_password" autocomplete="new-password" required minlength="8" placeholder="Re-enter password">
          </div>
          <button type="submit" class="btn-cc btn-cc-primary btn-cc-block btn-cc-lg">Update password</button>
        </form>

        <p class="auth-switch text-muted-cc"><a href="/login">Return to sign in</a></p>
      </div>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
