<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    pageEyebrow = 'Admin';
    pageHeading = 'System Reports';
    pageLead = 'Performance metrics across categories and events.';
    pageActions = '';
  %>
  <%- include('../partials/page-header') %>

  <main class="site-main">
    <div class="site-content overlap-panel max-1060">
      <div class="stat-row-4" style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px">
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Events completed</span>
          <span class="stat-value" style="font-size:26px"><%= kpis.eventsCompleted %></span>
        </div>
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Avg. fill rate</span>
          <span class="stat-value green" style="font-size:26px"><%= kpis.avgFillRate %></span>
        </div>
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Avg. attendance rate</span>
          <span class="stat-value" style="font-size:26px"><%= kpis.avgAttendance %></span>
        </div>
        <div class="stat-card" style="padding:18px 20px">
          <span class="stat-label" style="font-size:12.5px">Cancellation rate</span>
          <span class="stat-value amber" style="font-size:26px"><%= kpis.cancellationRate %></span>
        </div>
      </div>

      <div class="table-cc">
        <div class="panel-header">
          <span class="h-card">Performance by category</span>
        </div>
        <div class="table-scroll">
          <div class="table-cc-head" style="grid-template-columns:1.6fr 0.9fr 1.1fr 1.1fr 1.1fr 1.3fr">
            <span>Category</span><span>Events</span><span>Registrations</span><span>Attendance</span><span>Hours</span><span>Fill rate</span>
          </div>
          <% byCategory.forEach(function (c) { %>
            <div class="table-cc-row" style="grid-template-columns:1.6fr 0.9fr 1.1fr 1.1fr 1.1fr 1.3fr">
              <div class="d-flex align-items-center gap-2">
                <span style="width:11px;height:11px;border-radius:4px;background:<%= c.color %>;flex-shrink:0"></span>
                <span style="font-weight:700;color:#23271F"><%= c.name %></span>
              </div>
              <span style="font-weight:600;color:#3C4038"><%= c.events %></span>
              <span style="font-weight:600;color:#3C4038"><%= c.regs %></span>
              <span style="font-weight:600;color:#3C4038"><%= c.att %></span>
              <span style="font-weight:600;color:#3C4038"><%= c.hours %></span>
              <div class="d-flex align-items-center gap-2">
                <div class="cap-bar-track flex-fill" style="max-width:100px">
                  <div class="cap-bar-fill" style="width:<%= c.fill %>;background:<%= c.color %>"></div>
                </div>
                <span style="font-size:13px;font-weight:700;color:#23271F"><%= c.fill %></span>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="card-cc overflow-hidden">
        <div class="panel-header">
          <span class="h-card">Most-attended events</span>
        </div>
        <% topEvents.forEach(function (t) { %>
          <div class="list-row">
            <span style="width:26px;height:26px;border-radius:8px;background:#E7F2EA;color:#1E4D33;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:12.5px;flex-shrink:0"><%= t.rank %></span>
            <div class="flex-fill min-w-0">
              <div style="font-weight:600;color:#23271F"><%= t.name %></div>
              <div style="font-size:12.5px;color:#8B8778"><%= t.date %></div>
            </div>
            <span style="font-weight:700;color:#23271F"><%= t.attendees %> attended</span>
          </div>
        <% }) %>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
