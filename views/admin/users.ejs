<%- include('../partials/header') %>
<div class="app-shell" id="appShell">
  <%- include('../partials/sidebar') %>
  <main class="app-main">
    <% topbarTitle = 'User Management'; %>
    <% topbarActions = '<button type="button" class="btn-cc btn-cc-primary btn-cc-sm">+ Add user</button>'; %>
    <%- include('../partials/navbar') %>

    <div class="app-content">
      <div class="d-flex gap-2 align-items-center flex-wrap">
        <input type="text" class="form-control-cc" style="max-width:340px;padding:10px 14px;border-radius:10px;font-size:14px;background:#fff" placeholder="Search by name or email…">
        <select class="form-select-cc" style="width:auto;padding:10px 12px;border-radius:10px;font-size:14px;background:#fff">
          <option>All roles</option><option>Volunteer</option><option>Organiser</option><option>Admin</option>
        </select>
        <select class="form-select-cc" style="width:auto;padding:10px 12px;border-radius:10px;font-size:14px;background:#fff">
          <option>All statuses</option><option>Active</option><option>Pending approval</option><option>Suspended</option>
        </select>
        <span class="ms-auto text-soft" style="font-size:13.5px">1,318 users · showing <%= users.length %></span>
      </div>

      <div class="table-cc">
        <div class="table-scroll">
          <div class="table-cc-head" style="grid-template-columns:2fr 1.8fr 1fr 1.1fr 1fr 1.2fr">
            <span>User</span><span>Email</span><span>Role</span><span>Joined</span><span>Status</span><span style="text-align:right">Actions</span>
          </div>
          <% users.forEach(function (u) { %>
            <%
              const roleClass = u.role === 'Volunteer' ? 'badge-cc-confirmed' : (u.role === 'Organiser' ? 'badge-cc-organiser' : 'badge-cc-admin');
              const stClass = u.status === 'Active' ? 'badge-cc-active' : (u.status === 'Pending' ? 'badge-cc-pending' : 'badge-cc-danger');
            %>
            <div class="table-cc-row" style="grid-template-columns:2fr 1.8fr 1fr 1.1fr 1fr 1.2fr">
              <div class="d-flex align-items-center gap-2">
                <span class="avatar-cc sm" style="background:<%= u.avBg %>"><%= u.initials %></span>
                <span style="font-weight:600;color:#23271F"><%= u.name %></span>
              </div>
              <span class="text-muted-cc" style="font-size:13px"><%= u.email %></span>
              <span><span class="badge-cc <%= roleClass %>" style="font-size:11.5px;padding:4px 10px"><%= u.role %></span></span>
              <span class="text-muted-cc" style="font-size:13.5px"><%= u.joined %></span>
              <span><span class="badge-cc <%= stClass %>" style="font-size:11.5px;padding:4px 10px"><%= u.status %></span></span>
              <div class="d-flex gap-1 justify-content-end flex-wrap">
                <button type="button" class="btn-cc btn-cc-secondary btn-cc-xs">Edit</button>
                <% if (u.status === 'Pending') { %>
                  <button type="button" class="btn-cc btn-cc-xs" style="border:1px solid #BFDCC9;color:#1E4D33;background:#E7F2EA">Approve</button>
                <% } %>
                <% if (u.status === 'Active') { %>
                  <button type="button" class="btn-cc btn-cc-danger-outline btn-cc-xs">Suspend</button>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
