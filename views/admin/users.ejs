<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    pageEyebrow = 'Admin';
    pageHeading = 'User Management';
    pageLead = 'Manage community member, organiser and admin accounts.';
    pageActions = '';
  %>
  <%- include('../partials/page-header') %>

  <main class="site-main">
    <div class="site-content overlap-panel">
      <%- include('../partials/messages') %>

      <form method="GET" action="/admin/users" class="d-flex gap-2 align-items-center flex-wrap">
        <input type="text" name="q" value="<%= filters.q %>" class="form-control-cc" style="max-width:340px;padding:10px 14px;border-radius:10px;font-size:14px;background:#fff" placeholder="Search by name or email…">
        <select name="role" class="form-select-cc" style="width:auto;padding:10px 12px;border-radius:10px;font-size:14px;background:#fff">
          <option value="">All roles</option>
          <option value="community_member" <%= filters.role === 'community_member' ? 'selected' : '' %>>Community member</option>
          <option value="organiser" <%= filters.role === 'organiser' ? 'selected' : '' %>>Organiser</option>
          <option value="admin" <%= filters.role === 'admin' ? 'selected' : '' %>>Admin</option>
        </select>
        <select name="status" class="form-select-cc" style="width:auto;padding:10px 12px;border-radius:10px;font-size:14px;background:#fff">
          <option value="">All statuses</option>
          <option value="Active" <%= filters.status === 'Active' ? 'selected' : '' %>>Active</option>
          <option value="Suspended" <%= filters.status === 'Suspended' ? 'selected' : '' %>>Suspended</option>
        </select>
        <button type="submit" class="btn-cc btn-cc-secondary btn-cc-sm">Filter</button>
        <span class="ms-auto text-soft" style="font-size:13.5px"><%= totalUsers %> users · showing <%= users.length %></span>
      </form>

      <div class="table-cc">
        <div class="table-scroll">
          <div class="table-cc-head" style="grid-template-columns:1.7fr 1.7fr 1.2fr 0.9fr 0.9fr 2fr">
            <span>User</span><span>Email</span><span>Role</span><span>Joined</span><span>Status</span><span style="text-align:right">Actions</span>
          </div>
          <% if (!users.length) { %>
            <div class="table-cc-row" style="grid-template-columns:1fr">
              <span class="text-muted-cc">No users match your search or filters.</span>
            </div>
          <% } %>
          <% users.forEach(function (u) { %>
            <%
              const roleClass = u.role === 'community_member' ? 'badge-cc-confirmed' : (u.role === 'organiser' ? 'badge-cc-organiser' : 'badge-cc-admin');
              const stClass = u.status === 'Active' ? 'badge-cc-active' : 'badge-cc-danger';
            %>
            <div class="table-cc-row" style="grid-template-columns:1.7fr 1.7fr 1.2fr 0.9fr 0.9fr 2fr">
              <div class="d-flex align-items-center gap-2">
                <span class="avatar-cc sm" style="background:<%= u.avBg %>"><%= u.initials %></span>
                <span style="font-weight:600;color:#17342C"><%= u.name %></span>
              </div>
              <span class="text-muted-cc" style="font-size:13px"><%= u.email %></span>
              <form method="POST" action="/admin/users/<%= u.user_id %>/role" class="d-flex align-items-center gap-1">
                <select name="role" class="form-select-cc" style="width:auto;padding:5px 8px;border-radius:8px;font-size:12px;background:#fff">
                  <option value="community_member" <%= u.role === 'community_member' ? 'selected' : '' %>>Community member</option>
                  <option value="organiser" <%= u.role === 'organiser' ? 'selected' : '' %>>Organiser</option>
                  <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>Admin</option>
                </select>
                <button type="submit" class="btn-cc btn-cc-secondary btn-cc-xs">Save</button>
              </form>
              <span class="text-muted-cc" style="font-size:13.5px"><%= u.joined %></span>
              <span><span class="badge-cc <%= stClass %>" style="font-size:11.5px;padding:4px 10px"><%= u.status %></span></span>
              <div class="d-flex gap-1 justify-content-end flex-wrap">
                <% if (u.status === 'Active') { %>
                  <form method="POST" action="/admin/users/<%= u.user_id %>/status" onsubmit="return confirm('Suspend <%= u.name %>\'s account?');">
                    <input type="hidden" name="account_status" value="Suspended">
                    <button type="submit" class="btn-cc btn-cc-danger-outline btn-cc-xs">Suspend</button>
                  </form>
                <% } else { %>
                  <form method="POST" action="/admin/users/<%= u.user_id %>/status">
                    <input type="hidden" name="account_status" value="Active">
                    <button type="submit" class="btn-cc btn-cc-xs" style="border:1px solid #B9E3D3;color:#056047;background:#E8F7F0">Activate</button>
                  </form>
                <% } %>
                <form method="POST" action="/admin/users/<%= u.user_id %>/reset-access" onsubmit="return confirm('Create a one-time password-reset link for <%= u.name %>?');">
                  <button type="submit" class="btn-cc btn-cc-secondary btn-cc-xs">Reset access</button>
                </form>
                <form method="POST" action="/admin/users/<%= u.user_id %>/delete" onsubmit="var e = prompt('Type this account\'s email address to confirm permanent deletion:'); if (e === null) return false; this.confirm_email.value = e; return true;">
                  <input type="hidden" name="confirm_email" value="">
                  <button type="submit" class="btn-cc btn-cc-danger-outline btn-cc-xs">Delete</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
