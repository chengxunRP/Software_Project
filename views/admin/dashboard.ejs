<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    const pageEyebrow = 'Admin';
    const pageHeading = 'Admin Dashboard';
    const pageLead = 'Platform-wide activity across users, events and volunteer hours.';
    const pageActions = '<span style="font-size:13px;color:#D6F5F5">Data as of ' + asOf + '</span>';
  %>
  <%- include('../partials/page-header', { pageEyebrow: (typeof pageEyebrow !== 'undefined' ? pageEyebrow : ''), pageHeading: (typeof pageHeading !== 'undefined' ? pageHeading : ''), pageLead: (typeof pageLead !== 'undefined' ? pageLead : ''), pageActions: (typeof pageActions !== 'undefined' ? pageActions : '') }) %>

  <main class="site-main">
    <div class="site-content overlap-panel max-1080">
      <div class="stat-row-4" style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px">
        <div class="stat-card">
          <span class="stat-label">Total users</span>
          <span class="stat-value"><%= stats.totalUsers %></span>
          <span class="stat-note green"><%= stats.usersDelta %></span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Events (<%= chartYear %>)</span>
          <span class="stat-value"><%= stats.events2026 %></span>
          <span class="stat-note"><%= stats.eventsNote %></span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Registrations (<%= chartYear %>)</span>
          <span class="stat-value"><%= stats.registrations2026 %></span>
          <span class="stat-note"><%= stats.registrationsNote %></span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Volunteer hours (<%= chartYear %>)</span>
          <span class="stat-value green"><%= stats.hours2026 %></span>
          <span class="stat-note green"><%= stats.hoursDelta %></span>
        </div>
      </div>

      <div class="dashboard-split" style="display:grid;grid-template-columns:1.35fr 1fr;gap:20px;align-items:start">
        <div class="card-cc" style="padding:24px">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="h-card">Registrations per month — <%= chartYear %></span>
            <a href="/admin/reports" style="font-size:13.5px;font-weight:600">Full reports →</a>
          </div>
          <div class="bar-chart" style="height:170px">
            <% months.forEach(function (m) { %>
              <div class="bar-chart-item">
                <span class="val <%= m.current ? 'current' : '' %>" style="font-size:11.5px"><%= m.val %></span>
                <div class="bar <%= m.current ? 'current' : '' %>" style="height:<%= m.h %>px;max-width:46px"></div>
                <span class="label"><%= m.label %></span>
              </div>
            <% }) %>
          </div>
        </div>

        <div class="d-flex flex-column gap-3">
          <div class="card-cc" style="padding:22px">
            <div class="h-card mb-3">Users by role</div>
            <% userRoles.forEach(function (u) { %>
              <div class="mb-3">
                <div class="d-flex justify-content-between" style="font-size:13.5px">
                  <span style="font-weight:600;color:#33394A"><%= u.label %></span>
                  <span style="font-weight:700;color:#12161C"><%= u.count %></span>
                </div>
                <div class="cap-bar-track mt-1">
                  <div class="cap-bar-fill" style="width:<%= u.pct %>%;background:<%= u.color %>"></div>
                </div>
              </div>
            <% }) %>
          </div>

          <div class="card-cc" style="padding:22px">
            <div class="h-card mb-3">Hours by category — <%= hoursMonthLabel %></div>
            <% hoursByCat.forEach(function (h) { %>
              <div class="d-flex align-items-center gap-2 mb-2" style="font-size:13.5px">
                <span style="width:10px;height:10px;border-radius:3px;background:<%= h.color %>;flex-shrink:0"></span>
                <span style="font-weight:600;color:#33394A;flex:1"><%= h.label %></span>
                <span style="font-weight:700;color:#12161C"><%= h.val %></span>
              </div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
