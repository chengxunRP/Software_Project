<%- include('partials/header') %>
<div class="site-page public-page">
  <%- include('partials/navbar') %>

  <main class="auth-split">
    <aside class="auth-split-panel">
      <div class="auth-split-brand">
        <img src="/images/logo.png" alt="CommunityConnect SG" class="brand-mark">
        <span class="brand-name light">CommunityConnect <span class="sg">SG</span></span>
      </div>
        <h2>Welcome back to your community.</h2>
      <p>Log in to manage registrations, waiting lists and volunteer hours earned when you help.</p>
      <ul class="auth-benefit-list">
        <li>Join as Participant or Volunteer per event</li>
        <li>Separate waiting lists when places are full</li>
        <li>Track verified volunteer hours</li>
        <li>Stay updated on upcoming activities</li>
      </ul>
    </aside>

    <div class="auth-split-form">
      <div class="auth-split-form-inner">
        <h2 class="h-page" style="font-size:28px">Welcome back</h2>
        <p class="text-muted-cc mb-4">Log in to manage your event registrations and volunteer hours.</p>

        <%- include('partials/messages') %>

        <form class="auth-card flat" method="POST" action="/login">
          <div>
            <label class="form-label-cc" for="email">Email address</label>
            <input class="form-control-cc" type="email" id="email" name="email" autocomplete="email" required value="<%= typeof form !== 'undefined' && form.email ? form.email : '' %>" placeholder="e.g. weiling.tan@example.sg">
          </div>
          <div>
            <div class="d-flex justify-content-between align-items-baseline">
              <label class="form-label-cc mb-0" for="password">Password</label>
              <a href="/forgot-password" class="form-inline-link">Forgot your password?</a>
            </div>
            <input class="form-control-cc mt-2" type="password" id="password" name="password" autocomplete="current-password" required placeholder="••••••••">
          </div>
          <label class="form-check-cc">
            <input type="checkbox" name="remember">
            <span>Remember me on this device</span>
          </label>
          <button type="submit" class="btn-cc btn-cc-primary btn-cc-block btn-cc-lg">Log in</button>
        </form>

        <p class="auth-switch text-muted-cc">New here? <a href="/register">Create an account</a></p>
      </div>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
