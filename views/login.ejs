<%- include('partials/header') %>
<div class="public-page">
  <%- include('partials/navbar') %>

  <main class="auth-main">
    <div class="auth-card-wrap">
      <div class="text-center">
        <h1 class="h-page" style="font-size:28px">Welcome back</h1>
        <p class="mb-0 text-muted-cc">Log in to manage your event registrations and volunteer hours.</p>
      </div>

      <form class="auth-card" data-preview-only>
        <div>
          <label class="form-label-cc" for="email">Email address</label>
          <input class="form-control-cc" type="email" id="email" name="email" placeholder="e.g. weiling.tan@example.sg">
        </div>
        <div>
          <div class="d-flex justify-content-between align-items-baseline">
            <label class="form-label-cc mb-0" for="password">Password</label>
            <a href="/login" style="font-size:13px;font-weight:500">Forgot password?</a>
          </div>
          <input class="form-control-cc mt-2" type="password" id="password" name="password" placeholder="••••••••">
        </div>
        <label class="form-check-cc">
          <input type="checkbox" name="remember">
          <span>Remember me on this device</span>
        </label>
        <a href="/member/dashboard" class="btn-cc btn-cc-primary btn-cc-block" style="padding:12px 0;border-radius:11px;font-size:15px">Log in</a>
      </form>

      <div class="preview-as">
        <div class="label">Prototype — preview as</div>
        <div class="d-flex gap-2">
          <a href="/member/dashboard" class="btn-cc btn-cc-secondary btn-cc-sm flex-fill">Member</a>
          <a href="/organiser/dashboard" class="btn-cc btn-cc-secondary btn-cc-sm flex-fill">Organiser</a>
          <a href="/admin/dashboard" class="btn-cc btn-cc-secondary btn-cc-sm flex-fill">Admin</a>
        </div>
      </div>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
