<%- include('partials/header') %>
<div class="public-page">
  <%- include('partials/navbar') %>

  <main class="flex-fill">
    <div class="section-wrap wide" style="padding-top:40px">
      <div class="mb-3">
        <h1 class="h-page">Event Catalogue</h1>
        <p class="mb-0 text-muted-cc" style="font-size:15.5px"><%= events.length %> upcoming events across Singapore. Filter to find one near you.</p>
      </div>

      <form class="filter-bar mb-4" data-preview-only>
        <div>
          <label class="form-label-cc">Search</label>
          <input class="form-control-cc" type="text" name="q" placeholder="Keyword, e.g. clean-up">
        </div>
        <div>
          <label class="form-label-cc">Category</label>
          <select class="form-select-cc" name="category_id">
            <option value="">All categories</option>
            <% categories.forEach(function (c) { %>
              <option value="<%= c.category_id %>"><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div>
          <label class="form-label-cc">Date</label>
          <select class="form-select-cc" name="date">
            <option>Any date</option>
            <option>This weekend</option>
            <option>Next 7 days</option>
            <option>Next 30 days</option>
          </select>
        </div>
        <div>
          <label class="form-label-cc">Location</label>
          <select class="form-select-cc" name="location">
            <option>All areas</option>
            <option>East</option>
            <option>West</option>
            <option>North</option>
            <option>Central</option>
          </select>
        </div>
        <div>
          <label class="form-label-cc">Availability</label>
          <select class="form-select-cc" name="availability">
            <option>All events</option>
            <option>Spaces available</option>
            <option>Waitlist only</option>
          </select>
        </div>
        <button type="submit" class="btn-cc btn-cc-primary" style="padding:10px 20px;border-radius:9px">Apply</button>
      </form>

      <div class="row g-4 events-grid">
        <% events.forEach(function (ev) { %>
          <div class="col-md-6 col-lg-4">
            <div class="event-card">
              <div class="event-card-photo" style="height:130px">
                <span class="photo-label"><%= ev.photoLabel %></span>
              </div>
              <div class="event-card-body">
                <div class="d-flex justify-content-between align-items-center">
                  <span class="badge-cc badge-cc-cat" style="background:<%= ev.badgeBg %>;color:<%= ev.badgeFg %>"><%= ev.category %></span>
                  <% if (ev.full) { %>
                    <span class="badge-cc badge-cc-full" style="font-size:11.5px;padding:3px 9px">FULL</span>
                  <% } %>
                </div>
                <div class="event-card-title"><%= ev.event_name %></div>
                <div class="event-card-meta">
                  <span><%= ev.when %></span>
                  <span><%= ev.location %></span>
                </div>
                <div class="mt-auto">
                  <div class="cap-bar">
                    <div class="cap-bar-meta">
                      <span style="color:#6E7266"><%= ev.capLabel %></span>
                      <span style="color:<%= ev.capColor %>"><%= ev.full ? 'Waitlist open' : (ev.left + ' left') %></span>
                    </div>
                    <div class="cap-bar-track">
                      <div class="cap-bar-fill" style="width:<%= ev.pct %>%;background:<%= ev.capColor %>"></div>
                    </div>
                  </div>
                  <a href="/events/<%= ev.id %>" class="btn-cc btn-cc-outline btn-cc-block mt-3">View Details</a>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <div class="pagination-cc mt-4">
        <span class="active">1</span>
        <a href="/events">2</a>
        <a href="/events">→</a>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
