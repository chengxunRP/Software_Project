<%- include('partials/header') %>
<div class="site-page public-page">
  <%- include('partials/navbar') %>

  <main class="auth-split">
    <aside class="auth-split-panel">
      <div class="auth-split-brand">
        <img src="/images/logo.png" alt="CommunityConnect SG" class="brand-mark">
        <span class="brand-name light">CommunityConnect <span class="sg">SG</span></span>
      </div>
        <h2>We&rsquo;ll help you get back in.</h2>
      <p>Request a secure password reset and choose a new password for your account.</p>
      <ul class="auth-benefit-list">
        <li>Reset links are time-limited</li>
        <li>Each link can be used once</li>
        <li>Your current password stays private</li>
      </ul>
    </aside>

    <div class="auth-split-form">
      <div class="auth-split-form-inner">
        <h2 class="h-page" style="font-size:28px">Forgot your password?</h2>
        <p class="text-muted-cc mb-4">Enter the email address for your CommunityConnect SG account and we will prepare a secure password reset.</p>

        <%- include('partials/messages') %>

        <form class="auth-card flat" method="POST" action="/forgot-password">
          <div>
            <label class="form-label-cc" for="email">Email address</label>
            <input class="form-control-cc" type="email" id="email" name="email" autocomplete="email" required placeholder="e.g. weiling.tan@example.sg">
          </div>
          <button type="submit" class="btn-cc btn-cc-primary btn-cc-block btn-cc-lg">Continue</button>
        </form>

        <p class="auth-switch text-muted-cc">Remembered it? <a href="/login">Return to sign in</a></p>
      </div>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
