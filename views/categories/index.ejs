<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    pageEyebrow = 'Admin';
    pageHeading = 'Event Category Management';
    pageLead = 'Create, edit and manage categories used by organisers when creating events.';
  %>
  <%- include('../partials/page-header') %>

  <main class="site-main">
    <div class="site-content overlap-panel">
      <%- include('../partials/messages') %>

      <% if (!categories.length) { %>
        <div class="card-cc" style="padding:28px;text-align:center">
          <div style="font-size:16px;font-weight:700;color:#23271F">No categories have been created yet.</div>
          <div class="text-muted-cc mt-2" style="font-size:14.5px">Add an event category to help organisers classify events.</div>
          <a href="/admin/categories/new" class="btn-cc btn-cc-primary btn-cc-block mt-3">Add category</a>
        </div>
      <% } else { %>
        <div class="table-cc mt-2">
          <div class="table-scroll">
            <div class="table-cc-head" style="grid-template-columns:1.8fr 2fr 1fr 0.8fr 1.2fr">
              <span>Category</span>
              <span>Description</span>
              <span>Events</span>
              <span></span>
              <span style="text-align:right">Actions</span>
            </div>
            <% categories.forEach(function (category) { %>
              <div class="table-cc-row" style="grid-template-columns:1.8fr 2fr 1fr 0.8fr 1.2fr">
                <div style="font-weight:700;color:#23271F"><%= category.name %></div>
                <span class="text-muted-cc" style="font-size:13.5px"><%= category.description || 'No description' %></span>
                <span class="text-muted-cc" style="font-size:13.5px"><%= category.event_count %></span>
                <span></span>
                <div class="d-flex gap-1 justify-content-end flex-wrap">
                  <a href="/admin/categories/<%= category.category_id %>/edit" class="btn-cc btn-cc-secondary btn-cc-xs">Edit</a>
                  <button type="button" class="btn-cc btn-cc-danger-outline btn-cc-xs" data-open-modal data-delete-category-id="<%= category.category_id %>" data-event-name="<%= category.name %>">Delete</button>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>
  </main>

  <%- include('../partials/footer') %>
</div>

<form id="deleteCategoryForm" method="POST" action="" style="display:none"></form>
<div class="modal-cc" id="confirmModal">
  <div class="modal-cc-dialog" style="width:460px">
    <div class="modal-icon">!</div>
    <div>
      <div style="font-size:19px;font-weight:800;color:#23271F">Delete this category?</div>
      <div class="text-muted-cc mt-2" style="font-size:14.5px;line-height:1.55">This will remove <b id="modalEventName">this category</b>. Any events assigned to this category must be changed first.</div>
    </div>
    <div class="d-flex gap-2 justify-content-end">
      <button type="button" class="btn-cc btn-cc-secondary" data-close-modal>Keep category</button>
      <button type="button" class="btn-cc btn-cc-danger" data-confirm-delete>Yes, delete category</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
