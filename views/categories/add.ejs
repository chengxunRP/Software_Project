<%- include('../partials/header') %>
<div class="site-page app-shell" id="appShell">
  <%- include('../partials/navbar') %>

  <%
    pageEyebrow = 'Admin';
    pageHeading = 'Add Category';
    pageLead = 'Create a new event category that organisers can choose when creating events.';
  %>
  <%- include('../partials/page-header') %>

  <main class="site-main">
    <div class="site-content overlap-panel max-640">
      <%- include('../partials/messages') %>

      <form method="POST" action="/admin/categories" class="card-cc" style="border-radius:16px;padding:24px">
        <div class="mb-3">
          <label class="form-label-cc" for="name">Category name <span class="req">*</span></label>
          <input class="form-control-cc" type="text" id="name" name="name" value="<%= category.name %>">
        </div>
        <div class="mb-3">
          <label class="form-label-cc" for="description">Description</label>
          <textarea class="form-control-cc" id="description" name="description" rows="4"><%= category.description %></textarea>
        </div>
        <div class="d-flex gap-2 justify-content-end">
          <a href="/admin/categories" class="btn-cc btn-cc-secondary">Cancel</a>
          <button type="submit" class="btn-cc btn-cc-primary">Save category</button>
        </div>
      </form>
    </div>
  </main>

  <%- include('../partials/footer') %>
  <%- include('../partials/mobile-tabbar') %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
